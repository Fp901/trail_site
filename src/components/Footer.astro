---
// Footer — Part 5.6. Clean, minimal; necessary identity + a Privacy link, no clutter.
import { nav, site, withBase } from '../data/site';
import WhatsAppIcon from './WhatsAppIcon.astro';
import InstagramIcon from './InstagramIcon.astro';
import FacebookIcon from './FacebookIcon.astro';
// Full logo lockup (transparent PNG as a CSS mask — renders in the footer's cream).
import logoFull from '../assets/images/logo-full.png';
const year = new Date().getFullYear();
const telHref = `tel:${site.contact.phone.replace(/\s/g, '')}`;
// Social icons render only when a URL is configured (no dead links).
const hasSocial = Boolean(site.social.instagram || site.social.facebook);
---

<footer class="bg-earth text-cream">
  <div class="mx-auto max-w-screen-2xl px-6 py-16">
    <div class="grid gap-10 md:grid-cols-3">
      <div>
        <span
          class="brand-mark brand-mark--full"
          role="img"
          aria-label={site.brandName}
          style={`--logo-mark: url(${logoFull.src})`}
        ></span>
        <p class="mt-4 max-w-xs font-body text-sm leading-relaxed text-cream/70">
          {site.hook}
        </p>
        <p class="mt-4 font-body text-sm text-cream/60">{site.location}</p>
      </div>

      <nav aria-label="Footer">
        <p class="text-xs font-medium uppercase tracking-[0.14em] text-ochre">Explore</p>
        <ul class="mt-4 space-y-2.5">
          {
            nav.map((item) => (
              <li>
                <a
                  href={withBase(item.href)}
                  class="footer-link font-body text-sm text-cream/85"
                >
                  {item.label}
                </a>
              </li>
            ))
          }
        </ul>
      </nav>

      <div>
        <p class="text-xs font-medium uppercase tracking-[0.14em] text-ochre">Contact</p>
        <p class="mt-4">
          <a
            href={site.contact.whatsappUrl}
            target="_blank"
            rel="noopener"
            class="footer-link inline-flex items-center gap-2 font-body text-sm text-cream/85"
          >
            <WhatsAppIcon size={16} />
            WhatsApp {site.contact.name}
          </a>
        </p>
        <p class="mt-2">
          <a href={telHref} class="footer-link font-body text-sm text-cream/85">
            {site.contact.phone}
          </a>
        </p>
        <p class="mt-3 font-body text-sm text-cream/70">
          Office hours {site.contact.officeHours}
        </p>
        <p class="mt-3">
          <a href={withBase('/privacy')} class="footer-link font-body text-sm text-cream/85">Privacy</a>
        </p>

        {
          hasSocial && (
            <div class="footer-social">
              {site.social.instagram && (
                <a
                  href={site.social.instagram}
                  target="_blank"
                  rel="noopener"
                  class="footer-social__link"
                  aria-label="The Rooiberg Wander on Instagram"
                >
                  <InstagramIcon size={20} />
                </a>
              )}
              {site.social.facebook && (
                <a
                  href={site.social.facebook}
                  target="_blank"
                  rel="noopener"
                  class="footer-social__link"
                  aria-label="The Rooiberg Wander on Facebook"
                >
                  <FacebookIcon size={20} />
                </a>
              )}
            </div>
          )
        }
      </div>
    </div>

    <div
      class="mt-12 flex flex-wrap items-center justify-between gap-4 border-t border-cream/15 pt-6 font-body text-sm text-cream/60"
    >
      <p>&copy; {year} {site.operator}. All rights reserved.</p>
      <a href={withBase('/privacy')} class="footer-link">Privacy</a>
    </div>
  </div>
</footer>
