---
// Footer — Part 5.6. Clean, minimal; necessary identity + a Privacy link, no clutter.
import { nav, site, withBase } from '../data/site';
const year = new Date().getFullYear();
---

<footer class="bg-earth text-cream">
  <div class="mx-auto max-w-screen-2xl px-6 py-16">
    <div class="grid gap-10 md:grid-cols-3">
      <div>
        <p class="font-display text-xl font-bold">{site.name}</p>
        <p class="mt-3 max-w-xs font-body text-sm leading-relaxed text-cream/70">
          {site.hook}
        </p>
        <p class="mt-4 font-body text-sm text-cream/60">{site.location}</p>
      </div>

      <nav aria-label="Footer">
        <p class="text-xs font-medium uppercase tracking-[0.14em] text-ochre">Explore</p>
        <ul class="mt-4 space-y-2.5">
          {
            nav.map((item) => (
              <li>
                <a
                  href={withBase(item.href)}
                  class="footer-link font-body text-sm text-cream/85"
                >
                  {item.label}
                </a>
              </li>
            ))
          }
        </ul>
      </nav>

      <div>
        <p class="text-xs font-medium uppercase tracking-[0.14em] text-ochre">Contact</p>
        <p class="mt-4 font-body text-sm text-cream/85">{site.operator}</p>
        {/* Verbatim placeholder email ("rooberg" misspelling preserved — confirm before launch). */}
        <p class="mt-2">
          <a href={`mailto:${site.notifyEmail}`} class="footer-link font-body text-sm text-cream/85">
            {site.notifyEmail}
          </a>
        </p>
        <p class="mt-2">
          <a href={withBase('/privacy')} class="footer-link font-body text-sm text-cream/85">Privacy</a>
        </p>
      </div>
    </div>

    <div
      class="mt-12 flex flex-wrap items-center justify-between gap-4 border-t border-cream/15 pt-6 font-body text-sm text-cream/60"
    >
      <p>&copy; {year} {site.operator}. All rights reserved.</p>
      <a href={withBase('/privacy')} class="footer-link">Privacy</a>
    </div>
  </div>
</footer>
