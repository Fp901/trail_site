---
// SanctuaryCard — Part 7 / 8.3. Alternating editorial feature row (distinct-but-cohesive,
// not three identical boxes). Renders an astro:assets <Image> when a photo is supplied; else
// a labelled accent-tinted placeholder (4:3). Per-card accent via accentVar.
import { Image } from 'astro:assets';
import type { ImageMetadata } from 'astro';

interface Props {
  name: string;
  role: string;
  description: string;
  alt: string;
  accentVar: string;
  image?: ImageMetadata;
  reverse?: boolean;
}
const { name, role, description, alt, accentVar, image, reverse = false } = Astro.props;
---

<article
  class:list={['sanctuary', reverse && 'sanctuary--reverse']}
  style={`--accent: var(${accentVar});`}
>
  <div class="sanctuary__media">
    {
      image ? (
        <Image
          src={image}
          alt={alt}
          class="sanctuary__img"
          widths={[480, 768, 1024]}
          sizes="(min-width: 768px) 50vw, 100vw"
          loading="lazy"
        />
      ) : (
        <div class="sanctuary__placeholder" role="img" aria-label={alt} />
      )
    }
  </div>

  <div class="sanctuary__body">
    <p class="sanctuary__role">{role}</p>
    <h2 class="sanctuary__name">{name}</h2>
    <p class="sanctuary__desc">{description}</p>
  </div>
</article>
