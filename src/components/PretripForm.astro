---
// PretripForm — post-payment "further information" form. Vanilla-JS island (mirrors BookingWidget).
// Collects the comprehensive guest manifest + trip details (NO dietary — the trail is self-catered)
// and submits via the typed submitPretrip Action, which records submitted_at and stops reminders.
interface Props {
  token: string;
  groupSize: number;
  leadName: string;
  alreadySubmitted: boolean;
}
const { token, groupSize, leadName, alreadySubmitted } = Astro.props;
const guests = Array.from({ length: groupSize }, (_, i) => i + 1);
---

<form id="pretrip-form" class="bform" data-token={token} novalidate>
  {
    alreadySubmitted && (
      <p class="pretrip-note">
        We've already received your details. You can update anything below and resubmit.
      </p>
    )
  }

  <fieldset class="pretrip-section">
    <legend>Guest manifest ({groupSize} {groupSize === 1 ? 'guest' : 'guests'})</legend>
    <p class="pretrip-hint">
      Full names and ID/passport numbers are required for reserve access in a Big 5 area.
    </p>
    {
      guests.map((n) => (
        <div class="pretrip-guest" data-guest>
          <p class="pretrip-guest__num">Guest {n}{n === 1 ? ' · lead' : ''}</p>
          <div class="form-field">
            <label for={`g-name-${n}`}>Full name{n === 1 ? ' *' : ''}</label>
            {n === 1 && <span class="form-hint">As it appears on your ID or passport</span>}
            <input
              id={`g-name-${n}`}
              data-g-name
              type="text"
              maxlength="120"
              value={n === 1 ? leadName : ''}
              autocomplete="off"
              aria-describedby={n === 1 ? `g-name-err-${n}` : undefined}
            />
            {n === 1 && <span class="form-error" id={`g-name-err-${n}`} aria-live="polite"></span>}
          </div>
        </div>
      ))
    }
  </fieldset>

  <div class="form-field">
    <label for="pt-phone">Lead contact phone *</label>
    <span class="form-hint">e.g. +27 82 123 4567. Your guides need this number on trail.</span>
    <input
      id="pt-phone"
      type="tel"
      maxlength="40"
      autocomplete="tel"
      required
      aria-describedby="pt-phone-err"
    />
    <span class="form-error" id="pt-phone-err" aria-live="polite"></span>
  </div>

  <div class="form-field">
    <label for="pt-medical">Medical conditions, injuries, allergies or fitness limitations the guides should know</label>
    <span class="form-hint">Write "None" if not applicable.</span>
    <textarea id="pt-medical" rows="3" maxlength="3000"></textarea>
  </div>

  <div class="form-field">
    <label for="pt-vehicle">Vehicle make/model &amp; registration(s) for secure parking at Rotavi Lodge</label>
    <textarea id="pt-vehicle" rows="2" maxlength="500"></textarea>
  </div>

  <div class="form-field">
    <label for="pt-arrival">Estimated arrival time on Day 1</label>
    <span class="form-hint">Approximate time, to help the lodge team prepare your welcome.</span>
    <input id="pt-arrival" type="time" />
  </div>

  <div class="form-field">
    <label for="pt-requests">Anything else / special requests</label>
    <textarea id="pt-requests" rows="3" maxlength="3000"></textarea>
  </div>

  <div class="form-field" id="pt-selfcater-field">
    <label class="pretrip-check">
      <input type="checkbox" id="pt-selfcater" required aria-describedby="pt-selfcater-err" />
      <span>I understand the trail is fully self-catered: each group brings their own food and drinks. Each lodge has a kitchen, fridge, barbeque facilities, safe drinking water, ice and wood.</span>
    </label>
    <span class="form-error" id="pt-selfcater-err" aria-live="polite"></span>
  </div>

  <p class="pretrip-note">
    Your trail indemnity is signed in person on arrival at Rotavi Lodge, before the safety briefing,
    so there is nothing to sign here.
  </p>

  <p class="pretrip-note" style="font-size:0.8rem;color:color-mix(in srgb,#2C2C2C 55%,transparent);">
    Fields marked * are required.
  </p>

  {/* Honeypot */}
  <div class="hp" aria-hidden="true">
    <label>Company<input data-hp tabindex="-1" autocomplete="off" /></label>
  </div>

  <button type="submit" class="btn btn-primary bform__submit">Submit pre-trip details</button>
  <p class="bform__status" data-status role="status" aria-live="polite"></p>
</form>

<div class="pretrip-success" data-success hidden>
  <p class="pretrip-success__title">Thank you. Your details are in.</p>
  <p>We have everything we need to prepare for your trail. See you in the Rooiberg.</p>
</div>

<script>
  import { actions } from 'astro:actions';

  function initPretrip() {
    const form = document.getElementById('pretrip-form') as HTMLFormElement | null;
    if (!form || form.dataset.bound === 'true') return;
    form.dataset.bound = 'true';

    const status  = form.querySelector<HTMLElement>('[data-status]');
    const submit  = form.querySelector<HTMLButtonElement>('.bform__submit');
    const success = document.querySelector<HTMLElement>('[data-success]');

    const val = (sel: string) =>
      (form.querySelector<HTMLInputElement | HTMLTextAreaElement>(sel)?.value ?? '').trim();

    const setStatus = (msg: string) => {
      if (status) {
        status.textContent = msg;
        status.dataset.kind = 'error';
      }
    };

    // ---- Inline validation helpers ----------------------------------------
    type Rule = (v: string) => string | null;

    function firstErr(rawVal: string, rules: Rule[]): string | null {
      for (const r of rules) { const e = r(rawVal); if (e) return e; }
      return null;
    }

    function markField(wrapper: Element | null, msg: string | null): void {
      if (!wrapper) return;
      const errEl = wrapper.querySelector<HTMLElement>('.form-error');
      wrapper.classList.toggle('has-error', !!msg);
      if (errEl) errEl.textContent = msg ?? '';
    }

    function bindField(
      input: HTMLInputElement | HTMLTextAreaElement,
      rules: Rule[],
      wrapperSel?: string,
    ): void {
      const wrapper = wrapperSel
        ? document.querySelector(wrapperSel)
        : input.closest('.form-field');
      input.addEventListener('blur', () => markField(wrapper, firstErr(input.value, rules)));
      input.addEventListener('input', () => {
        if (wrapper?.classList.contains('has-error')) {
          markField(wrapper, firstErr(input.value, rules));
        }
      });
    }

    const phoneEl  = form.querySelector<HTMLInputElement>('#pt-phone')!;
    const caterEl  = form.querySelector<HTMLInputElement>('#pt-selfcater')!;

    // Lead guest row (first [data-guest] row)
    const leadRow    = form.querySelector<HTMLElement>('[data-guest]');
    const leadNameEl = leadRow?.querySelector<HTMLInputElement>('[data-g-name]') ?? null;

    const phoneRules: Rule[] = [
      v => !v.trim()                                  ? 'Please provide a contact number. Guides need this on trail.' : null,
      v => v.trim().replace(/\s/g, '').length < 7     ? 'Please enter a valid phone number.'                          : null,
    ];
    const nameRules: Rule[] = [
      v => !v.trim()           ? 'Please enter the lead guest\'s full name.' : null,
      v => v.trim().length < 2 ? 'Name must be at least 2 characters.'       : null,
    ];

    bindField(phoneEl, phoneRules);
    if (leadNameEl) bindField(leadNameEl, nameRules);

    // Checkbox: validate on change
    caterEl.addEventListener('change', () => {
      markField(document.getElementById('pt-selfcater-field'), caterEl.checked ? null : 'Please acknowledge the self-catering arrangement before submitting.');
    });

    // ---- Submit -----------------------------------------------------------
    form.addEventListener('submit', async (e) => {
      e.preventDefault();
      setStatus('');

      // Validate required fields; focus first error.
      type FieldCheck = [HTMLInputElement | HTMLTextAreaElement, Rule[]];
      const checks: FieldCheck[] = [
        ...(leadNameEl ? [[leadNameEl, nameRules] as FieldCheck] : []),
        [phoneEl, phoneRules],
      ];

      let firstBad: HTMLElement | null = null;
      for (const [el, rules] of checks) {
        const err = firstErr(el.value, rules);
        markField(el.closest('.form-field'), err);
        if (err && !firstBad) firstBad = el;
      }

      // Checkbox
      const caterWrapper = document.getElementById('pt-selfcater-field');
      if (!caterEl.checked) {
        markField(caterWrapper, 'Please acknowledge the self-catering arrangement before submitting.');
        if (!firstBad) firstBad = caterEl;
      } else {
        markField(caterWrapper, null);
      }

      if (firstBad) { firstBad.focus(); return; }

      // Lead guest name fallback guard (should have been caught above)
      const guests = Array.from(form.querySelectorAll<HTMLElement>('[data-guest]')).map((row) => ({
        name: (row.querySelector<HTMLInputElement>('[data-g-name]')?.value ?? '').trim(),
      }));

      if (!guests[0]?.name) {
        setStatus('Please enter the lead guest\'s full name.');
        leadNameEl?.focus();
        return;
      }

      const payload = {
        token:           form.dataset.token ?? '',
        leadPhone:       val('#pt-phone'),
        guests,
        medicalNotes:    val('#pt-medical'),
        vehicleReg:      val('#pt-vehicle'),
        arrivalTime:     val('#pt-arrival'),
        specialRequests: val('#pt-requests'),
        selfCateringAck: caterEl.checked,
        company: (form.querySelector<HTMLInputElement>('[data-hp]')?.value || undefined) as
          | string
          | undefined,
      };

      if (submit) {
        submit.disabled = true;
        submit.textContent = 'Saving…';
      }

      const { error } = await actions.submitPretrip(payload);

      if (error) {
        setStatus(error.message || 'Something went wrong. Please try again.');
        if (submit) {
          submit.disabled = false;
          submit.textContent = 'Submit pre-trip details';
        }
        return;
      }

      form.hidden = true;
      if (success) success.hidden = false;
      success?.scrollIntoView({ behavior: 'smooth', block: 'center' });
    });
  }

  document.addEventListener('astro:page-load', initPretrip);
</script>
