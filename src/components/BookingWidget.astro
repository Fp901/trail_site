---
// BookingWidget (Part 9.2) — vanilla-JS island. Collects dates/group/residency/lead details,
// shows a clearly-labelled estimate (server confirms the real total), and calls the typed
// createCheckout Action, then redirects to Paystack's hosted checkout. No price is ever sent.
import { formatRand } from '../data/rates';
import { computeQuote, SPLIT_THRESHOLD_DAYS, DEPOSIT_FRACTION } from '../lib/pricing';

// computeQuote (no startDate) returns the effective per-group total for the current pricing phase
// (launch discount applied when active). groupSize doesn't affect the group total — 1 is a placeholder.
const localQ = computeQuote({ residency: 'local', groupSize: 1 });
const intlQ  = computeQuote({ residency: 'international', groupSize: 1 });

// Deposit amounts (50/50 split, same math the server uses for deposit_balance plans).
const localDepositCents  = Math.round(localQ.totalCents * DEPOSIT_FRACTION);
const intlDepositCents   = Math.round(intlQ.totalCents  * DEPOSIT_FRACTION);
const localBalanceCents  = localQ.totalCents - localDepositCents;
const intlBalanceCents   = intlQ.totalCents  - intlDepositCents;

const fmt = (cents: number) => formatRand(cents / 100);
---

<form
  id="booking-form"
  class="bform"
  data-total-local={fmt(localQ.totalCents)}
  data-total-international={fmt(intlQ.totalCents)}
  data-deposit-local={fmt(localDepositCents)}
  data-deposit-international={fmt(intlDepositCents)}
  data-balance-local={fmt(localBalanceCents)}
  data-balance-international={fmt(intlBalanceCents)}
  data-split-days={SPLIT_THRESHOLD_DAYS}
  novalidate
>
  <div class="form-field bform__datefield">
    <span class="bform__callabel" id="bf-cal-label">Start date (Day 1, arrival)</span>
    <p class="bform__nextavail" data-nextavail hidden></p>
    <div class="bcal" data-calendar role="group" aria-labelledby="bf-cal-label">
      <div class="bcal__head">
        <button type="button" class="bcal__nav" data-cal-prev aria-label="Previous month">
          <span aria-hidden="true">&lsaquo;</span>
        </button>
        <span class="bcal__month" data-cal-month aria-live="polite"></span>
        <button type="button" class="bcal__nav" data-cal-next aria-label="Next month">
          <span aria-hidden="true">&rsaquo;</span>
        </button>
      </div>
      <div class="bcal__dow" aria-hidden="true">
        <span>Mon</span><span>Tue</span><span>Wed</span><span>Thu</span><span>Fri</span><span>Sat</span><span>Sun</span>
      </div>
      <div class="bcal__grid" data-cal-grid></div>
      <div class="bcal__legend" aria-hidden="true">
        <span class="bcal__key bcal__key--avail">Available</span>
        <span class="bcal__key bcal__key--taken">Taken</span>
        <span class="bcal__key bcal__key--out">Unavailable</span>
      </div>
    </div>
    <input id="bf-start" name="startDate" type="hidden" required />
    <p class="bcal__selected" data-cal-selected aria-live="polite"></p>
  </div>

  <div class="form-field">
    <label for="bf-group">Group size</label>
    <select id="bf-group" name="groupSize" required>
      {Array.from({ length: 12 }, (_, i) => i + 1).map((n) => (
        <option value={n}>
          {n}
          {n === 10 ? ' (recommended)' : ''}
          {n > 10 ? ' (by special arrangement)' : ''}
        </option>
      ))}
    </select>
  </div>

  <fieldset class="form-field">
    <legend>Residency</legend>
    <div class="bform__radios">
      <label class="bform__radio">
        <input type="radio" name="residency" value="local" checked /> Local resident
      </label>
      <label class="bform__radio">
        <input type="radio" name="residency" value="international" /> International visitor
      </label>
    </div>
  </fieldset>

  <div class="bform__grid">
    <div class="form-field">
      <label for="bf-name">Lead guest name</label>
      <span class="form-hint">First and last name, e.g. Sarah van der Merwe</span>
      <input
        id="bf-name"
        name="leadName"
        type="text"
        autocomplete="name"
        maxlength="120"
        required
        aria-describedby="bf-name-err"
      />
      <span class="form-error" id="bf-name-err" aria-live="polite"></span>
    </div>
    <div class="form-field">
      <label for="bf-email">Email</label>
      <span class="form-hint">We'll send your booking confirmation here.</span>
      <input
        id="bf-email"
        name="leadEmail"
        type="email"
        autocomplete="email"
        maxlength="180"
        required
        aria-describedby="bf-email-err"
      />
      <span class="form-error" id="bf-email-err" aria-live="polite"></span>
    </div>
    <div class="form-field">
      <label for="bf-phone">Mobile number</label>
      <span class="form-hint">e.g. +27 82 123 4567, so we can reach you if needed</span>
      <input
        id="bf-phone"
        name="leadPhone"
        type="tel"
        autocomplete="tel"
        maxlength="40"
        required
        aria-describedby="bf-phone-err"
      />
      <span class="form-error" id="bf-phone-err" aria-live="polite"></span>
    </div>
  </div>

  {/* Honeypot — must stay empty */}
  <div class="hp" aria-hidden="true">
    <label>Company<input name="company" tabindex="-1" autocomplete="off" /></label>
  </div>

  <div class="bform__pricing">
    <p class="bform__estimate">
      <span data-payment-label>Estimated total:</span>
      <strong data-estimate>{fmt(localQ.totalCents)}</strong> per group
      <span class="bform__estnote" data-est-note>Final amount confirmed at checkout.</span>
    </p>
    <p class="bform__balance-note" data-balance-note hidden>
      Remaining balance of <strong data-balance-amount></strong> due ~45 days before arrival. We'll email a secure payment link.
    </p>
    <p class="bform__deposit-hint" data-deposit-hint>
      Trips departing 30+ days away pay a <strong>50% deposit today</strong>, with the balance collected ~45 days before arrival.
    </p>
  </div>

  <p class="bform__flat">
    Exclusive use. One group at a time. Priced per trip regardless of group size.
  </p>

  <button type="submit" class="btn btn-primary bform__submit" data-submit>Continue to secure payment</button>

  <p class="bform__status" data-status role="status" aria-live="polite"></p>

  <p class="bform__privacy">
    By continuing you agree we may use your details to take and fulfil your booking. See our
    <a href="/privacy">Privacy Policy</a> and <a href="/rates#refund-heading">cancellation policy</a>.
  </p>
</form>

<script>
  import { actions } from 'astro:actions';

  // Anon, PUBLIC creds only (never the service-role key). The unavailable_windows view is
  // RLS-granted to anon and exposes ONLY blocked START dates (single dates, no ranges, no PII) —
  // the exact days a new booking may not start on (staggered-groups model).
  const SUPABASE_URL = import.meta.env.PUBLIC_SUPABASE_URL;
  const SUPABASE_ANON = import.meta.env.PUBLIC_SUPABASE_ANON_KEY;

  // Date helpers — UTC, ISO YYYY-MM-DD (mirror the server's lead-time/window rules).
  const pad = (n: number) => String(n).padStart(2, '0');
  const isoYMD = (y: number, m0: number, d: number) => `${y}-${pad(m0 + 1)}-${pad(d)}`;
  const addDaysIso = (iso: string, n: number) => {
    const dt = new Date(iso + 'T00:00:00Z');
    dt.setUTCDate(dt.getUTCDate() + n);
    return dt.toISOString().slice(0, 10);
  };
  const humanDate = (iso: string, opts: Intl.DateTimeFormatOptions) =>
    new Date(iso + 'T00:00:00Z').toLocaleDateString('en-ZA', { timeZone: 'UTC', ...opts });
  const daysBetween = (fromIso: string, toIso: string) =>
    Math.round((Date.parse(toIso + 'T00:00:00Z') - Date.parse(fromIso + 'T00:00:00Z')) / 86_400_000);

  // Blocked start dates: the exact days a new booking cannot start on. A date that falls inside an
  // existing trip's range but is not itself a start date stays bookable (lodges run staggered groups).
  async function fetchBlockedStarts(): Promise<Set<string>> {
    const blocked = new Set<string>();
    if (!SUPABASE_URL || !SUPABASE_ANON) return blocked;
    try {
      const res = await fetch(`${SUPABASE_URL}/rest/v1/unavailable_windows?select=start_date`, {
        headers: { apikey: SUPABASE_ANON, Authorization: `Bearer ${SUPABASE_ANON}` },
        cache: 'no-store', // always fetch fresh — a cancellation must free the date immediately
      });
      if (!res.ok) return blocked;
      const rows = await res.json();
      if (Array.isArray(rows)) {
        for (const r of rows as { start_date: string }[]) {
          if (r?.start_date) blocked.add(r.start_date);
        }
      }
      return blocked;
    } catch {
      return blocked;
    }
  }

  function setupCalendar(
    form: HTMLFormElement,
    startInput: HTMLInputElement,
    onDateSelected: (iso: string) => void,
  ): () => void {
    const noop = () => {};
    const cal = form.querySelector<HTMLElement>('[data-calendar]');
    if (!cal) return noop;
    const grid = cal.querySelector<HTMLElement>('[data-cal-grid]');
    const monthLabel = cal.querySelector<HTMLElement>('[data-cal-month]');
    const prevBtn = cal.querySelector<HTMLButtonElement>('[data-cal-prev]');
    const nextBtn = cal.querySelector<HTMLButtonElement>('[data-cal-next]');
    const field = cal.closest<HTMLElement>('.bform__datefield');
    const nextAvailEl = field?.querySelector<HTMLElement>('[data-nextavail]') ?? null;
    const selectedEl = field?.querySelector<HTMLElement>('[data-cal-selected]') ?? null;
    if (!grid || !monthLabel || !prevBtn || !nextBtn) return noop;

    const todayIso = new Date().toISOString().slice(0, 10);
    const earliest = addDaysIso(todayIso, 7); // 7-day minimum lead time (mirrors the server)
    const latest = addDaysIso(todayIso, 365); // 365-day ceiling (mirrors the server)

    let blocked = new Set<string>();
    let selected = '';
    const viewIdx = (y: number, m: number) => y * 12 + m;
    const minIdx = viewIdx(+todayIso.slice(0, 4), +todayIso.slice(5, 7) - 1);
    const maxIdx = viewIdx(+latest.slice(0, 4), +latest.slice(5, 7) - 1);
    let view = { y: +earliest.slice(0, 4), m: +earliest.slice(5, 7) - 1 };

    // Staggered groups: a day is "taken" ONLY if it exactly matches an existing booking's start date
    // (two groups cannot start on the same day → both at Lodge 1, night 1). A day inside another
    // trip's range but not itself a start date stays selectable. Mirrors the DB unique-start-date
    // index, so a selectable date can never 409 at submit.
    const stateOf = (d: string): 'out' | 'taken' | 'avail' => {
      if (d < earliest || d > latest) return 'out';
      return blocked.has(d) ? 'taken' : 'avail';
    };

    const nextAvailable = (): string | null => {
      let d = earliest;
      while (d <= latest) {
        if (stateOf(d) === 'avail') return d;
        d = addDaysIso(d, 1);
      }
      return null;
    };

    const selectDate = (iso: string) => {
      selected = iso;
      startInput.value = iso;
      if (selectedEl)
        selectedEl.textContent =
          'Selected start: ' +
          humanDate(iso, { weekday: 'long', day: 'numeric', month: 'long', year: 'numeric' });
      render();
      onDateSelected(iso);
    };

    const render = () => {
      monthLabel.textContent = humanDate(isoYMD(view.y, view.m, 1), {
        month: 'long',
        year: 'numeric',
      });
      prevBtn.disabled = viewIdx(view.y, view.m) <= minIdx;
      nextBtn.disabled = viewIdx(view.y, view.m) >= maxIdx;
      grid.innerHTML = '';
      const firstDow = new Date(Date.UTC(view.y, view.m, 1)).getUTCDay(); // 0=Sun
      const lead = (firstDow + 6) % 7; // Monday-first
      for (let i = 0; i < lead; i++) {
        const blank = document.createElement('span');
        blank.className = 'bcal__cell bcal__cell--blank';
        grid.appendChild(blank);
      }
      const days = new Date(Date.UTC(view.y, view.m + 1, 0)).getUTCDate();
      for (let day = 1; day <= days; day++) {
        const iso = isoYMD(view.y, view.m, day);
        const st = stateOf(iso);
        const cell = document.createElement('button');
        cell.type = 'button';
        cell.textContent = String(day);
        cell.className = `bcal__cell bcal__cell--${st}`;
        const human = humanDate(iso, {
          weekday: 'long',
          day: 'numeric',
          month: 'long',
          year: 'numeric',
        });
        if (st === 'avail') {
          cell.setAttribute('aria-label', human);
          cell.setAttribute('aria-pressed', iso === selected ? 'true' : 'false');
          if (iso === selected) cell.classList.add('is-selected');
          cell.addEventListener('click', () => selectDate(iso));
        } else {
          cell.disabled = true;
          cell.setAttribute('aria-label', `${human}, ${st === 'taken' ? 'taken' : 'unavailable'}`);
        }
        grid.appendChild(cell);
      }
    };

    const updateNextAvail = () => {
      if (!nextAvailEl) return;
      const na = nextAvailable();
      nextAvailEl.textContent = na
        ? 'Next available: ' + humanDate(na, { day: 'numeric', month: 'long', year: 'numeric' })
        : 'No dates are currently available. Please contact us.';
      nextAvailEl.hidden = false;
    };

    prevBtn.addEventListener('click', () => {
      const idx = viewIdx(view.y, view.m) - 1;
      if (idx < minIdx) return;
      view = { y: Math.floor(idx / 12), m: ((idx % 12) + 12) % 12 };
      render();
    });
    nextBtn.addEventListener('click', () => {
      const idx = viewIdx(view.y, view.m) + 1;
      if (idx > maxIdx) return;
      view = { y: Math.floor(idx / 12), m: ((idx % 12) + 12) % 12 };
      render();
    });

    const refetch = () => {
      fetchBlockedStarts().then((b) => {
        blocked = b;
        updateNextAvail();
        const na = nextAvailable();
        if (na && !selected) view = { y: +na.slice(0, 4), m: +na.slice(5, 7) - 1 };
        render();
      });
    };

    render(); // immediate paint (no taken dates yet)
    refetch(); // load blocked dates and jump to first available month

    return refetch;
  }

  function initBooking() {
    const form = document.getElementById('booking-form') as HTMLFormElement | null;
    if (!form || form.dataset.bound === 'true') return;
    form.dataset.bound = 'true';

    const estimate    = form.querySelector<HTMLElement>('[data-estimate]');
    const paymentLabel = form.querySelector<HTMLElement>('[data-payment-label]');
    const estNote     = form.querySelector<HTMLElement>('[data-est-note]');
    const balanceNote = form.querySelector<HTMLElement>('[data-balance-note]');
    const balanceAmt  = form.querySelector<HTMLElement>('[data-balance-amount]');
    const depositHint = form.querySelector<HTMLElement>('[data-deposit-hint]');
    const status      = form.querySelector<HTMLElement>('[data-status]');
    const startInput  = form.querySelector<HTMLInputElement>('#bf-start');
    const submit      = form.querySelector<HTMLButtonElement>('[data-submit]');
    const nameInput   = form.querySelector<HTMLInputElement>('#bf-name')!;
    const emailInput  = form.querySelector<HTMLInputElement>('#bf-email')!;
    const phoneInput  = form.querySelector<HTMLInputElement>('#bf-phone')!;

    // ---- Inline validation helpers ----------------------------------------
    type Rule = (v: string) => string | null;

    function firstErr(val: string, rules: Rule[]): string | null {
      for (const r of rules) { const e = r(val); if (e) return e; }
      return null;
    }

    function markField(wrapper: Element | null, msg: string | null): void {
      if (!wrapper) return;
      const errEl = wrapper.querySelector<HTMLElement>('.form-error');
      wrapper.classList.toggle('has-error', !!msg);
      if (errEl) errEl.textContent = msg ?? '';
    }

    function bindField(
      input: HTMLInputElement | HTMLTextAreaElement,
      rules: Rule[],
    ): void {
      const wrapper = input.closest('.form-field');
      input.addEventListener('blur', () => markField(wrapper, firstErr(input.value, rules)));
      input.addEventListener('input', () => {
        if (wrapper?.classList.contains('has-error')) {
          markField(wrapper, firstErr(input.value, rules));
        }
      });
    }

    const nameRules: Rule[] = [
      v => !v.trim()           ? 'Please enter your full name.'                   : null,
      v => v.trim().length < 2 ? 'Name must be at least 2 characters.'            : null,
    ];
    const emailRules: Rule[] = [
      v => !v.trim()           ? 'Please enter your email address.'               : null,
      v => !/^[^\s@]+@[^\s@]+\.[^\s@]{2,}$/.test(v.trim())
                               ? "That doesn't look like a valid email address."  : null,
    ];
    const phoneRules: Rule[] = [
      v => !v.trim()                              ? 'Please enter a mobile number.' : null,
      v => v.trim().replace(/[\s\-()]/g, '').length < 7
                                                  ? 'Please enter a valid phone number.' : null,
    ];

    bindField(nameInput,  nameRules);
    bindField(emailInput, emailRules);
    bindField(phoneInput, phoneRules);

    const SPLIT_DAYS = Number(form.dataset.splitDays ?? 30);
    const todayIso = new Date().toISOString().slice(0, 10); // UTC — display only, server re-validates

    const totals    = { local: form.dataset.totalLocal ?? '',    international: form.dataset.totalInternational ?? '' };
    const deposits  = { local: form.dataset.depositLocal ?? '',  international: form.dataset.depositInternational ?? '' };
    const balances  = { local: form.dataset.balanceLocal ?? '',  international: form.dataset.balanceInternational ?? '' };

    const residency = () =>
      form.querySelector<HTMLInputElement>('input[name="residency"]:checked')?.value ?? 'local';

    const updateEstimate = () => {
      const res = residency() as 'local' | 'international';
      const startIso = startInput?.value ?? '';
      const isDeposit =
        startIso.length === 10 && daysBetween(todayIso, startIso) >= SPLIT_DAYS;

      if (isDeposit) {
        if (paymentLabel) paymentLabel.textContent = '50% deposit due today:';
        if (estimate)     estimate.textContent = deposits[res] ?? '';
        if (estNote)      estNote.textContent = 'Full amount confirmed at checkout.';
        if (balanceNote)  balanceNote.hidden = false;
        if (balanceAmt)   balanceAmt.textContent = balances[res] ?? '';
        if (depositHint)  depositHint.hidden = true; // redundant once we show the live split
        if (submit)       submit.textContent = 'Pay deposit & continue to checkout';
      } else {
        if (paymentLabel) paymentLabel.textContent = startIso ? 'Total due today:' : 'Estimated total:';
        if (estimate)     estimate.textContent = totals[res] ?? '';
        if (estNote)      estNote.textContent = 'Final amount confirmed at checkout.';
        if (balanceNote)  balanceNote.hidden = true;
        if (depositHint)  depositHint.hidden = false;
        if (submit)       submit.textContent = 'Continue to secure payment';
      }
    };

    if (startInput) setupCalendar(form, startInput, () => updateEstimate());

    form
      .querySelectorAll<HTMLInputElement>('input[name="residency"]')
      .forEach((el) => el.addEventListener('change', updateEstimate));
    updateEstimate();

    const setStatus = (msg: string, kind: 'error' | 'info' = 'error') => {
      if (!status) return;
      status.textContent = msg;
      status.dataset.kind = kind;
    };

    // If the user returned from an abandoned Paystack checkout (browser back OR full reload),
    // redirect to /booking/cancel which cancels the pending booking server-side and shows a
    // clear "no payment taken" message with a link back to try again.
    const PENDING_KEY = 'rw_checkout_pending';
    const pendingRef = sessionStorage.getItem(PENDING_KEY);
    if (pendingRef) {
      sessionStorage.removeItem(PENDING_KEY);
      window.location.replace(
        `/booking/cancel?reference=${encodeURIComponent(pendingRef)}`,
      );
    }

    form.addEventListener('submit', async (e) => {
      e.preventDefault();
      setStatus('', 'info');
      const fd = new FormData(form);

      // Validate all required fields; focus first error.
      const startVal = String(fd.get('startDate') ?? '');
      if (!startVal) {
        setStatus('Please choose a start date from the calendar.');
        return;
      }
      const fieldChecks: Array<[HTMLInputElement | HTMLTextAreaElement, Rule[]]> = [
        [nameInput,  nameRules],
        [emailInput, emailRules],
        [phoneInput, phoneRules],
      ];
      let firstBad: HTMLElement | null = null;
      for (const [el, rules] of fieldChecks) {
        const err = firstErr(el.value, rules);
        markField(el.closest('.form-field'), err);
        if (err && !firstBad) firstBad = el;
      }
      if (firstBad) { firstBad.focus(); return; }

      const payload = {
        startDate: startVal,
        groupSize: Number(fd.get('groupSize') ?? 0),
        residency: String(fd.get('residency') ?? 'local') as 'local' | 'international',
        leadName: String(fd.get('leadName') ?? ''),
        leadEmail: String(fd.get('leadEmail') ?? ''),
        leadPhone: String(fd.get('leadPhone') ?? ''),
        company: (fd.get('company') as string) || undefined,
      };

      if (submit) {
        submit.disabled = true;
        submit.textContent = 'Taking you to checkout…';
      }

      const { data, error } = await actions.createCheckout(payload);

      if (error) {
        setStatus(error.message || 'Something went wrong. Please try again.');
        if (submit) {
          submit.disabled = false;
          updateEstimate(); // restore correct button label
        }
        return;
      }
      if (data?.authorizationUrl) {
        // Store the reference so on back-navigation we can cancel the pending booking immediately.
        sessionStorage.setItem('rw_checkout_pending', data.reference ?? '');
        window.location.href = data.authorizationUrl;
      }
    });
  }

  document.addEventListener('astro:page-load', initBooking);

  // bfcache restore: user pressed the browser back button from the Paystack page.
  // The browser thaws the frozen DOM (button still disabled) without firing astro:page-load.
  // Re-enable the button and re-run initBooking (which also checks sessionStorage for the message).
  // For full-reload back-navigation (no bfcache), astro:page-load fires instead and initBooking
  // already handles the sessionStorage check — so no message logic lives here.
  window.addEventListener('pageshow', (e) => {
    if (!(e as PageTransitionEvent).persisted) return;
    const form = document.getElementById('booking-form') as HTMLFormElement | null;
    if (!form) return;
    const sub = form.querySelector<HTMLButtonElement>('[data-submit]');
    if (sub) sub.disabled = false;
    form.removeAttribute('data-bound');
    initBooking(); // includes the sessionStorage check + message
  });
</script>
