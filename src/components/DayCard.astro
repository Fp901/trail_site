---
// DayCard — Part 7. One itinerary day. distanceKm null => "No walking" (Day 1).
// Walking days may carry an elevation profile image (route height profile).
import { Image } from 'astro:assets';
import type { ImageMetadata } from 'astro';

interface Props {
  day: number;
  title: string;
  distanceKm: number | null;
  from?: string;
  to?: string;
  description: string;
  colorVar?: string;
  elevation?: ImageMetadata;
  elevationAlt?: string;
  elevationCaption?: string;
}
const {
  day,
  title,
  distanceKm,
  from,
  to,
  description,
  colorVar,
  elevation,
  elevationAlt,
  elevationCaption,
} = Astro.props;
const accent = colorVar ?? '--color-green';
const noWalking = distanceKm === null;
---

<li class="daycard" style={`--accent: var(${accent});`}>
  <div class="daycard__marker">
    <span class="daycard__daylabel">Day</span>
    <span class="daycard__num">{day}</span>
  </div>
  <div class="daycard__body">
    <div class="daycard__head">
      <h3 class="daycard__title">{title}</h3>
      <span class:list={['daycard__distance', noWalking && 'daycard__distance--rest']}>
        {noWalking ? 'No walking' : `~${distanceKm} km`}
      </span>
    </div>
    {
      from && to && (
        <p class="daycard__route">
          <span>{from}</span>
          <span class="daycard__arrow" aria-hidden="true">&rarr;</span>
          <span>{to}</span>
        </p>
      )
    }
    <p class="daycard__desc">{description}</p>
    {
      elevation && (
        <figure class="daycard__elevation">
          <Image
            src={elevation}
            alt={elevationAlt ?? `Day ${day} elevation profile`}
            widths={[320, 480, 640]}
            sizes="(min-width: 640px) 360px, 90vw"
            loading="lazy"
          />
          {elevationCaption && <figcaption>{elevationCaption}</figcaption>}
        </figure>
      )
    }
  </div>
</li>
