---
// Beta popup (Booking v2, go-live gating). Explains: online booking opens BOOKING_OPEN_DATE;
// the trail is in beta until BETA_END_DATE; earlier dates are family-and-friends by enquiry or
// WhatsApp only, at a discount. Vanilla-JS, no framework (Part 2). Dismissible once per browser
// session (sessionStorage) — reappears on the next visit/session. Mobile-first: a bottom sheet
// under 640px, a centred card above. Honours prefers-reduced-motion.
import { withBase, site } from '../data/site';
import { BOOKING_OPEN_DISPLAY, BETA_END_DISPLAY } from '../data/rates';
---

<div
  id="beta-banner"
  class="beta-banner"
  role="dialog"
  aria-modal="true"
  aria-labelledby="beta-banner-heading"
  hidden
>
  <div class="beta-banner__backdrop" data-beta-dismiss></div>
  <div class="beta-banner__card">
    <button type="button" class="beta-banner__close" id="beta-banner-close" aria-label="Close">
      <span aria-hidden="true">&times;</span>
    </button>
    <p class="beta-banner__eyebrow">We're in beta</p>
    <h2 id="beta-banner-heading" class="beta-banner__heading">Booking opens {BOOKING_OPEN_DISPLAY}</h2>
    <p class="beta-banner__body">
      Online booking is accepted for start dates from {BOOKING_OPEN_DISPLAY}. We are in beta
      until {BETA_END_DISPLAY}. For a trip before then, dates are available to family and friends
      at a significant discount, by enquiry or WhatsApp only.
    </p>
    <div class="beta-banner__actions">
      <a href={withBase('/rates#enquire-heading')} class="btn btn-primary">Send an enquiry</a>
      <a href={site.contact.whatsappUrl} target="_blank" rel="noopener" class="btn btn-secondary">
        WhatsApp {site.contact.name}
      </a>
    </div>
    <button type="button" class="beta-banner__continue" id="beta-banner-continue">
      Continue to the site
    </button>
  </div>
</div>

<script>
  const KEY = 'rw_beta_banner_dismissed';

  function initBetaBanner() {
    const banner = document.getElementById('beta-banner');
    if (!banner || banner.dataset.bound === 'true') return;
    banner.dataset.bound = 'true';

    if (sessionStorage.getItem(KEY) === 'true') return;

    const closeBtn = document.getElementById('beta-banner-close');
    const continueBtn = document.getElementById('beta-banner-continue');
    const backdrop = banner.querySelector<HTMLElement>('[data-beta-dismiss]');
    let lastFocused: HTMLElement | null = null;

    const focusable = () =>
      Array.from(banner.querySelectorAll<HTMLElement>('a[href], button:not([disabled])'));

    const close = () => {
      sessionStorage.setItem(KEY, 'true');
      banner.classList.remove('is-open');
      document.documentElement.style.overflow = '';
      document.removeEventListener('keydown', onKeydown);
      const hide = () => {
        if (!banner.classList.contains('is-open')) banner.hidden = true;
        banner.removeEventListener('transitionend', hide);
      };
      banner.addEventListener('transitionend', hide);
      window.setTimeout(hide, 350); // fallback if no transitionend (e.g. reduced motion)
      lastFocused?.focus();
    };

    const onKeydown = (e: KeyboardEvent) => {
      if (e.key === 'Escape') {
        close();
        return;
      }
      if (e.key === 'Tab') {
        const f = focusable();
        if (f.length === 0) return;
        const first = f[0];
        const last = f[f.length - 1];
        if (e.shiftKey && document.activeElement === first) {
          e.preventDefault();
          last.focus();
        } else if (!e.shiftKey && document.activeElement === last) {
          e.preventDefault();
          first.focus();
        }
      }
    };

    const open = () => {
      lastFocused = document.activeElement as HTMLElement;
      banner.hidden = false;
      requestAnimationFrame(() => banner.classList.add('is-open'));
      document.documentElement.style.overflow = 'hidden';
      focusable()[0]?.focus();
      document.addEventListener('keydown', onKeydown);
    };

    closeBtn?.addEventListener('click', close);
    continueBtn?.addEventListener('click', close);
    backdrop?.addEventListener('click', close);

    // Open on first paint of a fresh session — a small delay lets the page settle first.
    window.setTimeout(open, 400);
  }

  document.addEventListener('astro:page-load', initBetaBanner);
</script>
