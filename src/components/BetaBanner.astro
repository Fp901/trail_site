---
// Beta notice (Booking v2.1) — an inline, non-dismissible banner on the Rates & Booking page
// only (not a sitewide modal). Explains: online booking opens BOOKING_OPEN_DATE; dates before
// that are family-and-friends by enquiry or WhatsApp, at a discount. The site is static, so
// "today" is baked in at build time as a best-effort default — a tiny script re-checks the
// visitor's actual date on load and corrects the banner (and the enquiry disclosure elsewhere
// on the page) without needing a redeploy on launch day.
import { BOOKING_OPEN_DATE, BOOKING_OPEN_DISPLAY } from '../data/rates';
import { todaySast } from '../lib/pricing';

const isBetaAtBuildTime = todaySast() < BOOKING_OPEN_DATE;
---

<div class="beta-notice" data-beta-notice data-until={BOOKING_OPEN_DATE} hidden={!isBetaAtBuildTime}>
  <p class="beta-notice__eyebrow">We're in beta</p>
  <p class="beta-notice__body">
    Online booking is accepted for start dates from {BOOKING_OPEN_DISPLAY}. Dates before then are
    available to family and friends at a significant discount, by enquiry or WhatsApp only.
  </p>
</div>

<script>
  // Self-corrects without a deploy: compares the visitor's actual date (SAST) to the
  // build-time default above. Also flips the enquiry disclosure elsewhere on the page, if
  // present, so the two stay in sync.
  function initBetaNotice() {
    const notice = document.querySelector<HTMLElement>('[data-beta-notice]');
    const disclosure = document.querySelector<HTMLDetailsElement>('[data-enquire-disclosure]');
    const openDate = notice?.dataset.until ?? disclosure?.dataset.until;
    if (!openDate) return;
    const todaySast = new Date().toLocaleDateString('en-CA', { timeZone: 'Africa/Johannesburg' });
    const isBeta = todaySast < openDate;
    if (notice) notice.hidden = !isBeta;
    if (disclosure) disclosure.open = isBeta;
  }
  document.addEventListener('astro:page-load', initBetaNotice);
</script>
