---
// Primary navigation — Part 5.6 / Part 7. Sticky top bar driven by site.ts.
// `overHero`: when true (Home), the bar is transparent with light text over the hero
// and switches to cream/blur + dark text on scroll. When false (interior pages), it is
// solid cream from the top. The MobileMenu overlay (md:hidden) handles small screens.
import { Image } from 'astro:assets';
import { nav, site, withBase } from '../data/site';
import MobileMenu from './MobileMenu.astro';
// Ridge brand mark, pre-coloured (no CSS mask): the cream version shows over the dark hero, the
// earth version on the cream/scrolled/interior header. CSS swaps them via the header state attrs.
import ridgeCream from '../assets/images/logo-mark-cream.png';
import ridgeEarth from '../assets/images/logo-mark-earth.png';

interface Props {
  overHero?: boolean;
}
const { overHero = false } = Astro.props;

const path = Astro.url.pathname;
const isActive = (href: string) => {
  const target = withBase(href);
  return href === '/' ? path === target : path === target || path.startsWith(target + '/');
};
---

<header class="site-header fixed inset-x-0 top-0 z-40" data-over-hero={String(overHero)}>
  <nav
    aria-label="Primary"
    class="mx-auto flex max-w-screen-2xl items-center justify-between px-6 py-4"
  >
    <a href={withBase('/')} class="site-brand">
      <span class="brand-mark" aria-hidden="true">
        <Image class="brand-mark__light" src={ridgeCream} alt="" widths={[160, 320]} sizes="160px" loading="eager" />
        <Image class="brand-mark__dark" src={ridgeEarth} alt="" widths={[160, 320]} sizes="160px" loading="eager" />
      </span>
      <span class="site-brand__text">
        <span class="site-brand__name">{site.brandName}</span>
        <span class="site-brand__tagline">{site.headerTagline}</span>
      </span>
    </a>

    <div class="hidden items-center gap-6 lg:flex xl:gap-8">
      <ul class="flex items-center gap-6 xl:gap-8">
        {
          nav.map((item) => (
            <li>
              <a
                href={withBase(item.href)}
                class="nav-link font-body text-sm"
                aria-current={isActive(item.href) ? 'page' : undefined}
              >
                {item.label}
              </a>
            </li>
          ))
        }
      </ul>
      <a href={withBase('/rates#book')} class="nav-cta">Book dates</a>
    </div>

    <MobileMenu />
  </nav>
</header>

<script>
  // Toggle data-scrolled on the sticky header (cream/blur once scrolled — Part 5.6).
  // The scroll listener is attached once to window (persists across View Transitions);
  // setupNav re-syncs the freshly-rendered header on every astro:page-load.
  function setupNav() {
    const header = document.querySelector('.site-header');
    if (!header) return;
    header.setAttribute('data-scrolled', String(window.scrollY > 8));

    const w = window as unknown as { __navScrollBound?: boolean };
    if (!w.__navScrollBound) {
      w.__navScrollBound = true;
      window.addEventListener(
        'scroll',
        () => {
          const h = document.querySelector('.site-header');
          if (h) h.setAttribute('data-scrolled', String(window.scrollY > 8));
        },
        { passive: true },
      );
    }
  }
  document.addEventListener('astro:page-load', setupNav);
</script>
