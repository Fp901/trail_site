---
// AmenityIcon — small inline-SVG icon set for lodge amenities (Part 5.2: no generic icon
// libraries; hand-drawn 24px strokes that inherit currentColor so each card's accent applies).
interface Props {
  name:
    | 'parking'
    | 'pool'
    | 'suite'
    | 'kitchen'
    | 'barbeque'
    | 'water'
    | 'ice'
    | 'wood'
    | 'wifi'
    | 'view';
  size?: number;
}
const { name, size = 20 } = Astro.props;

const paths: Record<string, string> = {
  // Rounded square with a P
  parking:
    'M5 3h14a2 2 0 0 1 2 2v14a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2Zm5 14v-4m0 0V7h3.5a2.5 2.5 0 0 1 0 6H10Z',
  // Three layered waves
  pool: 'M3 8c1.5-1.4 3.5-1.4 5 0s3.5 1.4 5 0 3.5-1.4 5 0 2 .9 3 .9M3 13c1.5-1.4 3.5-1.4 5 0s3.5 1.4 5 0 3.5-1.4 5 0 2 .9 3 .9M3 18c1.5-1.4 3.5-1.4 5 0s3.5 1.4 5 0 3.5-1.4 5 0 2 .9 3 .9',
  // Bed
  suite:
    'M3 18v-8m0 4h18v4m0-4v-2a3 3 0 0 0-3-3h-8v5M6 11.5a1.5 1.5 0 1 0 0-3 1.5 1.5 0 0 0 0 3Z',
  // Fridge
  kitchen:
    'M7 2h10a1.5 1.5 0 0 1 1.5 1.5v17A1.5 1.5 0 0 1 17 22H7a1.5 1.5 0 0 1-1.5-1.5v-17A1.5 1.5 0 0 1 7 2Zm-1.5 8h13M15 6v2m0 5v3',
  // Flame over grill line
  barbeque:
    'M12 3c1 2.5 4 4 4 8a4 4 0 0 1-8 0c0-1.6.6-2.8 1.4-4 .4 1 1 1.6 1.8 2 .1-2.2.1-4.2.8-6ZM5 20h14',
  // Droplet
  water: 'M12 3s6 6.5 6 11a6 6 0 0 1-12 0c0-4.5 6-11 6-11Z',
  // Snowflake (simple)
  ice: 'M12 2v20M4 6l16 12M20 6L4 18M8.5 4 12 6.5 15.5 4M8.5 20 12 17.5l3.5 2.5',
  // Stacked logs
  wood: 'M9 15a3 3 0 1 0 0 6 3 3 0 0 0 0-6Zm6 0a3 3 0 1 0 0 6 3 3 0 0 0 0-6Zm-3-6a3 3 0 1 0 0 6 3 3 0 0 0 0-6Zm-6.5 5L9 9m6 0 3.5 5',
  // WiFi arcs
  wifi: 'M4 9.5C8.5 5.5 15.5 5.5 20 9.5M6.8 13c3-2.6 7.4-2.6 10.4 0M9.6 16.4c1.4-1.2 3.4-1.2 4.8 0M12 19.5h.01',
  // Sun over mountains
  view: 'M16 8a3 3 0 1 0-.01 0M2 20l6-9 4 6 3-4 7 7H2Z',
};
---

<svg
  width={size}
  height={size}
  viewBox="0 0 24 24"
  fill="none"
  stroke="currentColor"
  stroke-width="1.6"
  stroke-linecap="round"
  stroke-linejoin="round"
  aria-hidden="true"
>
  <path d={paths[name]}></path>
</svg>
