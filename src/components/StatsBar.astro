---
// StatsBar — Part 7 / 8.1. Four verbatim stats from site.ts, directly below the hero.
// Earth band, cream type, ochre dividers (ochre used sparingly — Part 5.4). Legible at 380px.
import { stats } from '../data/site';
---

<section class="statsbar" aria-label="The trail at a glance">
  <ul class="statsbar__grid mx-auto max-w-screen-2xl">
    {
      stats.map((s) => (
        <li class="statsbar__item">
          <span class="statsbar__value">{s.value}</span>
          <span class="statsbar__label">{s.label}</span>
        </li>
      ))
    }
  </ul>
</section>
