---
// RatesTable — Booking v2. Two products: the private (exclusive) trail and shared Monday
// departures. Per group or per person as appropriate — never a fabricated combined figure.
import { rates } from '../data/rates';
import { withBase } from '../data/site';
---

<div class="rates">
  {
    rates.map((r) => (
      <div class:list={['ratecard', r.id === 'exclusive' && 'ratecard--primary']}>
        <p class="ratecard__label">{r.label}</p>
        <p class="ratecard__price">
          {r.headline}
        </p>
        <p class="ratecard__incl">{r.headlineNote}</p>
        {r.notes.map((n) => (
          <p class="ratecard__note">{n}</p>
        ))}
        <p class="ratecard__cta">
          <a href={withBase('/rates#book')}>
            Check available dates <span aria-hidden="true">&darr;</span>
          </a>
        </p>
      </div>
    ))
  }
</div>
