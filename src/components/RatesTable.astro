---
// RatesTable — Part 7 / 8.5. SA residents vs foreign nationals; strong VAT-inclusive total
// with the "incl. VAT (15%) & conservation levies" note. Per group, never per person (Part 12).
import { rates, formatRand, vatPortion, LAUNCH_OFFER, launchPrice } from '../data/rates';
---

<div class="rates">
  {
    rates.map((r) => {
      const shown = LAUNCH_OFFER ? launchPrice(r.total) : r.total;
      return (
        <div class:list={['ratecard', r.id === 'local' && 'ratecard--primary']}>
          <p class="ratecard__label">{r.label}</p>
          {LAUNCH_OFFER && <p class="ratecard__launchbadge">Launch offer · 50% off</p>}
          <p class="ratecard__price">
            {formatRand(shown)}
            <span class="ratecard__per">per group</span>
          </p>
          {LAUNCH_OFFER && (
            <p class="ratecard__was">
              Normally <s>{formatRand(r.total)}</s>
            </p>
          )}
          <p class="ratecard__incl">incl. VAT (15%) &amp; conservation levies · up to 12 guests</p>
          <p class="ratecard__note">{r.note}</p>
          <p class="ratecard__vat">Includes {formatRand(vatPortion(shown))} VAT.</p>
        </div>
      );
    })
  }
</div>
