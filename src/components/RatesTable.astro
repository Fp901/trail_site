---
// RatesTable — Booking v2.1. Three purchasable options, equal visual weight: private
// self-catered, private catered, shared Monday. Per-person figures ONLY ever appear on the
// shared card — the two private cards are flat group rates and never show a divided figure.
import { rates } from '../data/rates';
import { withBase } from '../data/site';
---

<div class="rates">
  {
    rates.map((r) => (
      <div class="ratecard">
        <p class="ratecard__label">{r.label}</p>
        <p class="ratecard__bestfor">{r.bestFor}</p>
        <p class="ratecard__price">
          {r.heroPrice}
          <span class="ratecard__unit">{r.heroUnit}</span>
        </p>
        {r.smallPrint && <p class="ratecard__smallprint">{r.smallPrint}</p>}
        <p class="ratecard__subline">{r.subline}</p>
        {r.notes.map((n) => (
          <p class="ratecard__note">{n}</p>
        ))}
        <p class="ratecard__cta">
          <a href={withBase('/rates#book')}>
            Check available dates <span aria-hidden="true">&darr;</span>
          </a>
        </p>
      </div>
    ))
  }
</div>
