---
// Home (/) — Part 8.1. Restructured to tease and sell; detail lives on the dedicated pages
// (safety + FAQ on /logistics, pricing + inclusions on /rates). Flow: hero → intro → statement
// band → why → how it works → lodges → testimonials → review → book.
import { Image } from 'astro:assets';
import Layout from '../layouts/Layout.astro';
import Section from '../components/Section.astro';
import Hero from '../components/Hero.astro';
import StatsBar from '../components/StatsBar.astro';
import Testimonials from '../components/Testimonials.astro';
import GoogleReview from '../components/GoogleReview.astro';
import { withBase } from '../data/site';
import { LAUNCH_OFFER, LAUNCH_DATE, LAUNCH_DISCOUNT } from '../data/rates';
import { sanctuaries } from '../data/sanctuaries';
import heroImage from '../assets/images/hero-rooiberg-mountains-sunset.jpg';
import panorama from '../assets/images/rooiberg-dusk-panorama.jpg';
import {
  organizationSchema,
  webPageSchema,
  breadcrumbSchema,
  touristTripSchema,
} from '../data/schema';

const title = 'The Rooiberg Wander | Malaria-free Big 5 slackpacking trail';
const description =
  'A self-catering walking safari in the Waterberg. 3 nights and 3 days through 15,000 ha of malaria-free Big 5 wilderness near Rooiberg, Limpopo, 2.5 hours from Johannesburg.';

const jsonLd = [
  organizationSchema,
  webPageSchema({ path: '/', name: title, description }),
  breadcrumbSchema([{ name: 'Home', path: '/' }]),
  touristTripSchema,
];

// Trust-signal band (below the hero). Kept short; the "Why walk" section below covers the detail.
const trustSignals = ['Malaria-Free', 'Armed Guides', 'Private Group'];

// How the trail works — four plain steps.
const steps = [
  {
    n: '1',
    title: 'Choose your dates and book',
    text: 'Pick a start date and pay securely online. A 50% deposit holds dates booked 30 or more days ahead.',
  },
  {
    n: '2',
    title: 'Arrive at Rotavi Lodge',
    text: 'Park securely, meet your two armed guides and settle in. There is no walking on the arrival day.',
  },
  {
    n: '3',
    title: 'Walk from lodge to lodge',
    text: 'Three walking days of 15 to 20 km, sleeping at a different lodge each night. Your bags travel ahead.',
  },
  {
    n: '4',
    title: 'Finish and head home',
    text: 'After the final morning walk you return to Rotavi Lodge, freshen up, collect your car and drive home.',
  },
];

// Lodge teasers (image-led) from the shared sanctuaries data.
const lodgeContext: Record<string, string> = {
  rotavi: 'Nights 1 and 4',
  oukraal: 'Night 2',
  viervanacht: 'Night 3',
};
---

<Layout
  title={title}
  description={description}
  path="/"
  navOverHero={true}
  jsonLd={jsonLd}
>
  <Hero
    image={heroImage}
    imageAlt="Golden-hour light over the layered mountains of the Rooiberg, Limpopo."
  />
  <StatsBar />

  {/* Trust signals — slim band of proof points directly below the hero/stats. */}
  <div class="trust-bar">
    <ul class="trust-bar__list">
      {trustSignals.map((s) => <li>{s}</li>)}
    </ul>
  </div>

  {
    LAUNCH_OFFER && (
      <Section bg="cream" space="md">
        <div class="launch-banner">
          <p class="launch-banner__eyebrow">Soft launch</p>
          <p class="launch-banner__lead">
            The trail opens on {LAUNCH_DATE}. During the soft-launch period, family and friends
            book at {Math.round(LAUNCH_DISCOUNT * 100)}% off the standard group rate.
          </p>
          <p class="mt-4">
            <a href={withBase('/rates')} class="btn btn-primary">See soft-launch rates</a>
          </p>
        </div>
      </Section>
    )
  }

  {/* Intro — short and factual. Detail lives on /the-trail. */}
  <Section bg="cream" labelledby="promise-heading">
    <div class="max-w-3xl">
      <p class="font-body text-sm font-medium uppercase tracking-[0.18em] text-green">
        The unpack-and-walk trail
      </p>
      <h2
        id="promise-heading"
        class="mt-4 font-display text-3xl text-earth sm:text-4xl md:text-5xl"
      >
        A three-day walking safari in the Waterberg
      </h2>
      <p class="mt-6 max-w-2xl font-body text-lg leading-relaxed text-charcoal sm:text-xl">
        The Rooiberg Wander is a 3-night, 3-day self-catered walking trail through 15,000 hectares
        of malaria-free Big 5 reserve near Rooiberg in Limpopo, 2.5 hours by road from Johannesburg.
      </p>
      <p class="mt-5 max-w-2xl font-body text-base leading-relaxed text-charcoal/85">
        You walk from one private lodge to the next while your luggage and provisions are moved
        ahead each day. You carry only a daypack.
      </p>
      <p class="mt-10">
        <a href={withBase('/rates')} class="btn btn-primary">View rates and book the trail</a>
      </p>
    </div>
  </Section>

  {/* Statement band — dark visual break; one factual line over an atmospheric image. */}
  <section class="statement-band" aria-label="About the trail">
    <Image
      class="statement-band__img"
      src={panorama}
      alt="Dusk over the Rooiberg mountains in the Waterberg, Limpopo."
      widths={[768, 1280, 1920]}
      sizes="100vw"
      loading="lazy"
    />
    <div class="statement-band__scrim"></div>
    <div class="statement-band__inner">
      <p class="statement-band__text">
        A guided walking trail on foot through a private Big 5 reserve, with no game-drive vehicles
        and no through-traffic.
      </p>
    </div>
  </section>

  {/* Why walk the trail — three grounded benefits. */}
  <Section bg="cream" labelledby="why-heading" space="md">
    <h2 id="why-heading" class="max-w-3xl font-display text-2xl text-earth sm:text-3xl">
      Why walk the Rooiberg Wander
    </h2>
    <p class="mt-5 max-w-2xl font-body leading-relaxed text-charcoal/85">
      A point-to-point trail: you walk from one private lodge to the next and sleep somewhere new
      each night, with a pool, a fire and a bed at the end of every day.
    </p>
    <div class="mt-10 grid gap-8 sm:grid-cols-3">
      <div class="border-t-2 border-ochre pt-4">
        <h3 class="font-display text-xl text-earth">Big 5 on foot</h3>
        <p class="mt-2 font-body text-sm leading-relaxed text-charcoal/80">
          Mountain summits, deep valleys, riverbeds and open plains, crossed at ground level with
          two armed guides rather than viewed from a vehicle.
        </p>
      </div>
      <div class="border-t-2 border-ochre pt-4">
        <h3 class="font-display text-xl text-earth">Unpack and walk</h3>
        <p class="mt-2 font-body text-sm leading-relaxed text-charcoal/80">
          Self-catered, but you carry only a daypack. Your food, drinks and bags travel ahead to
          the next lodge each day, kept cool and dry.
        </p>
      </div>
      <div class="border-t-2 border-ochre pt-4">
        <h3 class="font-display text-xl text-earth">Private group</h3>
        <p class="mt-2 font-body text-sm leading-relaxed text-charcoal/80">
          You walk with your own group and two guides, and each lodge is reserved for your group on
          the night you stay. Up to ten guests, with an optional two by arrangement.
        </p>
      </div>
    </div>
  </Section>

  {/* How it works — four steps. */}
  <Section bg="cream" space="md" labelledby="how-heading" class="border-t border-hairline">
    <div class="max-w-3xl">
      <p class="font-body text-sm font-medium uppercase tracking-[0.18em] text-green">
        Step by step
      </p>
      <h2 id="how-heading" class="mt-4 font-display text-2xl text-earth sm:text-3xl md:text-4xl">
        How the trail works
      </h2>
    </div>
    <ol class="howit">
      {
        steps.map((s) => (
          <li class="howit__step">
            <span class="howit__num" aria-hidden="true">{s.n}</span>
            <h3 class="howit__title">{s.title}</h3>
            <p class="howit__text">{s.text}</p>
          </li>
        ))
      }
    </ol>
    <p class="mt-10">
      <a href={withBase('/the-trail')} class="btn btn-secondary">See the full day-by-day trail</a>
    </p>
  </Section>

  {/* The lodges — image-led teasers into /accommodation. */}
  <Section bg="cream" space="md" labelledby="lodges-heading" class="border-t border-hairline">
    <div class="max-w-3xl">
      <p class="font-body text-sm font-medium uppercase tracking-[0.18em] text-green">
        Where you sleep
      </p>
      <h2 id="lodges-heading" class="mt-4 font-display text-2xl text-earth sm:text-3xl md:text-4xl">
        Three private safari lodges
      </h2>
    </div>
    <ul class="home-lodges">
      {
        sanctuaries.map((s) => (
          <li>
            <a href={withBase('/accommodation')} class="home-lodge group">
              <div class="home-lodge__media">
                {s.image && (
                  <Image
                    src={s.image}
                    alt={s.alt}
                    class="home-lodge__img"
                    widths={[400, 600]}
                    sizes="(min-width: 768px) 33vw, 100vw"
                    loading="lazy"
                  />
                )}
              </div>
              <p class="home-lodge__context">{lodgeContext[s.id]}</p>
              <h3 class="home-lodge__name">{s.name}</h3>
              <p class="home-lodge__role">{s.role}</p>
            </a>
          </li>
        ))
      }
    </ul>
    <p class="mt-10">
      <a href={withBase('/accommodation')} class="btn btn-secondary">See the lodges</a>
    </p>
  </Section>

  {/* Testimonials — renders only when real reviews exist. */}
  <Testimonials />

  {/* Google review — renders only when the Google Business Profile link is set. */}
  <GoogleReview />

  {/* Final CTA. */}
  <Section bg="earth" space="md" labelledby="cta-heading">
    <div class="max-w-3xl">
      <h2 id="cta-heading" class="font-display text-3xl text-cream sm:text-4xl">
        Ready to walk the Rooiberg?
      </h2>
      <p class="mt-5 max-w-2xl font-body leading-relaxed text-cream/85">
        Check available dates and book online, or read the full day-by-day trail first.
      </p>
      <div class="mt-8 flex flex-wrap gap-4">
        <a href={withBase('/rates')} class="btn btn-primary">Check dates and book</a>
        <a href={withBase('/the-trail')} class="btn btn-ghost">See the trail</a>
      </div>
    </div>
  </Section>
</Layout>
