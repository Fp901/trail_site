---
// Home (/) — Part 8.1. Hero → StatsBar → Promise → teasers.
import { Image } from 'astro:assets';
import Layout from '../layouts/Layout.astro';
import Section from '../components/Section.astro';
import Hero from '../components/Hero.astro';
import StatsBar from '../components/StatsBar.astro';
import { withBase } from '../data/site';
import { LAUNCH_OFFER, LAUNCH_DATE, inclusions, exclusions } from '../data/rates';
import { faqs } from '../data/logistics';
import heroImage from '../assets/images/hero-rooiberg-mountains-sunset.jpg';
import panorama from '../assets/images/rooiberg-dusk-panorama.jpg';
import {
  organizationSchema,
  webPageSchema,
  breadcrumbSchema,
  touristTripSchema,
} from '../data/schema';

const title = 'The Rooiberg Wander | Malaria-free Big 5 slackpacking trail';
const description =
  'A self-catering walking safari in the Waterberg. 3 nights and 3 days through 15,000 ha of malaria-free Big 5 wilderness near Rooiberg, Limpopo, 2.5 hours from Johannesburg.';

const jsonLd = [
  organizationSchema,
  webPageSchema({ path: '/', name: title, description }),
  breadcrumbSchema([{ name: 'Home', path: '/' }]),
  touristTripSchema,
];

// Teasers into the deeper pages (copy mirrors §8.8; Rates shows the VAT-inclusive total).
const teasers = [
  {
    index: '01',
    title: 'The Trail',
    href: '/the-trail',
    text: 'No walking on arrival day; then three mountain days of 15 to 20 km, lodge to lodge. After the final walk on Day 4 you shower, share a meal and head home.',
  },
  {
    index: '02',
    title: 'The Safari Lodges',
    href: '/accommodation',
    text: 'Rotavi Lodge, Oukraal and ViervanAcht. Three private safari lodges, each with its own character.',
  },
  {
    index: '03',
    title: 'Rates & Booking',
    href: '/rates',
    text: 'Launching 1 October 2026 with a 50% Launch Phase discount. R60,000 per exclusive group of up to ten, incl. VAT and all conservation levies.',
  },
];

// Homepage trust-signal band (below the hero).
const trustSignals = [
  'Private Big 5 Reserve',
  'Malaria-Free',
  'Armed Professional Guides',
  'Exclusive Group Use',
  'Self-Catered & Ported', // NB: changed from "Fully Catered" — the trail is self-catered (see summary)
];

// FAQ highlights — 4 common questions pulled verbatim from the full /logistics FAQ (no duplication
// of content; the answers live in data/logistics.ts). A "Read more" links to the full list.
const faqHighlightQuestions = [
  'What is slackpacking?',
  'Is the area malaria-free?',
  'How fit do I need to be?',
  'How big is the group?',
];
const faqHighlights = faqHighlightQuestions
  .map((q) => faqs.find((f) => f.q === q))
  .filter((f): f is (typeof faqs)[number] => Boolean(f));
---

<Layout
  title={title}
  description={description}
  path="/"
  navOverHero={true}
  jsonLd={jsonLd}
>
  <Hero
    image={heroImage}
    imageAlt="Golden-hour light over the layered mountains of the Rooiberg, Limpopo."
  />
  <StatsBar />

  {/* Trust signals — slim band of proof points directly below the hero/stats. */}
  <div class="trust-bar">
    <ul class="trust-bar__list">
      {trustSignals.map((s) => <li>{s}</li>)}
    </ul>
  </div>

  {
    LAUNCH_OFFER && (
      <Section bg="cream" space="md">
        <div class="launch-banner">
          <p class="launch-banner__eyebrow">Launch offer</p>
          <p class="launch-banner__lead">
            The trail launches on {LAUNCH_DATE}. Book a Launch Phase departure and save 50% on every
            rate.
          </p>
          <p class="mt-4">
            <a href={withBase('/rates')} class="btn btn-primary">See launch rates</a>
          </p>
        </div>
      </Section>
    )
  }

  {/* Promise — the unpack-and-walk model. GEO H2 answered in the first sentence (Part 10.5). */}
  <Section bg="cream" labelledby="promise-heading">
    <div class="max-w-3xl">
      <p class="font-body text-sm font-medium uppercase tracking-[0.18em] text-green">
        The unpack-and-walk trail
      </p>
      <h2
        id="promise-heading"
        class="mt-4 font-display text-3xl text-earth sm:text-4xl md:text-5xl"
      >
        A walk through 15,000 hectares of Big 5 reserve
      </h2>
      <p class="mt-6 max-w-2xl font-body text-lg leading-relaxed text-charcoal sm:text-xl">
        The Rooiberg Wander is a 3-night, 3-day self-catered slackpacking trail. You cross 15,000
        hectares of malaria-free Big 5 reserve near Rooiberg in Limpopo, 2.5 hours drive from
        Johannesburg. You walk; we move everything else.
      </p>
      <p class="mt-5 max-w-2xl font-body text-base leading-relaxed text-charcoal/85">
        Over three days you cross the Groenkop and Elandsberg mountains on foot, through deep
        kloofs, riverbeds and open plains, with two armed trail guides the whole way. You
        bring your own food and drinks. Your bags and provisions move between camps each day,
        kept cool and dry, and staff at each lodge help with cleaning, cooking, the barbeque and
        the washing-up. The trail is yours alone: we cater for groups of up to ten, with an
        optional two extra by special arrangement.
      </p>

      <ul class="mt-8 flex flex-wrap gap-x-8 gap-y-3 font-body text-sm font-medium text-earth">
        <li class="border-l-2 border-ochre pl-3">100% malaria-free</li>
        <li class="border-l-2 border-ochre pl-3">Two armed trail guides</li>
        <li class="border-l-2 border-ochre pl-3">Luggage moved daily</li>
        <li class="border-l-2 border-ochre pl-3">Exclusive use · up to 10</li>
      </ul>

      <p class="mt-10">
        <a href={withBase('/rates')} class="btn btn-primary">View rates and book the trail</a>
      </p>
    </div>
  </Section>

  <figure class="media-band">
    <Image
      src={panorama}
      alt="Dusk over the Rooiberg mountains, with a bush dinner set beside a lily-covered waterhole."
      widths={[768, 1280]}
      sizes="100vw"
      loading="lazy"
    />
  </figure>

  <Section bg="cream" labelledby="why-heading" space="md">
    <h2 id="why-heading" class="max-w-3xl font-display text-2xl text-earth sm:text-3xl">
      You sleep somewhere new every night
    </h2>
    <p class="mt-5 max-w-2xl font-body leading-relaxed text-charcoal/85">
      This is a point-to-point trail. You walk from one private safari lodge to the next and sleep
      somewhere new each night, with a pool, a camp fire and a real bed at the end of every day.
    </p>
    <div class="mt-10 grid gap-8 sm:grid-cols-3">
      <div class="border-t-2 border-ochre pt-4">
        <h3 class="font-display text-xl text-earth">Big 5 on foot</h3>
        <p class="mt-2 font-body text-sm leading-relaxed text-charcoal/80">
          A malaria-free Big 5 reserve, walked at ground level with two armed trail guides the
          whole way.
        </p>
      </div>
      <div class="border-t-2 border-ochre pt-4">
        <h3 class="font-display text-xl text-earth">Unpack and walk</h3>
        <p class="mt-2 font-body text-sm leading-relaxed text-charcoal/80">
          Self-catered, but you carry only a daypack. Your food, drinks and bags travel ahead to
          the next camp each day, kept cool and dry.
        </p>
      </div>
      <div class="border-t-2 border-ochre pt-4">
        <h3 class="font-display text-xl text-earth">Yours alone</h3>
        <p class="mt-2 font-body text-sm leading-relaxed text-charcoal/80">
          The whole trail and all three safari lodges are yours. A group of ten (recommended), with
          an optional two by special arrangement.
        </p>
      </div>
    </div>
  </Section>

  {/* What's included / what's not — pulled from the same source as the Rates page (data/rates.ts). */}
  <Section bg="cream" space="md" labelledby="included-home-heading" class="border-t border-hairline">
    <div class="max-w-3xl">
      <p class="font-body text-sm font-medium uppercase tracking-[0.18em] text-green">
        One flat rate, per group
      </p>
      <h2
        id="included-home-heading"
        class="mt-4 font-display text-2xl text-earth sm:text-3xl md:text-4xl"
      >
        What the price includes
      </h2>
      <p class="mt-4 font-body leading-relaxed text-charcoal/85">
        VAT and all conservation levies are included. Here is exactly what your group rate covers —
        and the few things to arrange yourself.
      </p>
    </div>
    <div class="mt-10 grid gap-10 md:grid-cols-2">
      <div>
        <h3 class="font-display text-xl text-earth">Included</h3>
        <ul class="incl-list incl-list--in">
          {inclusions.map((i) => <li>{i}</li>)}
        </ul>
      </div>
      <div>
        <h3 class="font-display text-xl text-earth">Not included</h3>
        <ul class="incl-list incl-list--out">
          {exclusions.map((i) => <li>{i}</li>)}
        </ul>
      </div>
    </div>
    <p class="mt-8">
      <a href={withBase('/rates')} class="btn btn-secondary">See full rates &amp; book</a>
    </p>
  </Section>

  {/* FAQ highlights — 4 common questions; the full list lives on /logistics (not duplicated). */}
  <Section bg="cream" space="md" labelledby="faq-home-heading" class="border-t border-hairline">
    <div class="max-w-3xl">
      <p class="font-body text-sm font-medium uppercase tracking-[0.18em] text-green">
        Good to know
      </p>
      <h2 id="faq-home-heading" class="mt-4 font-display text-2xl text-earth sm:text-3xl md:text-4xl">
        Common questions
      </h2>
    </div>
    <dl class="mt-10 grid max-w-4xl gap-8 sm:grid-cols-2">
      {
        faqHighlights.map((f) => (
          <div class="border-t-2 border-ochre pt-4">
            <dt class="font-display text-lg text-earth">{f.q}</dt>
            <dd class="mt-2 font-body text-sm leading-relaxed text-charcoal/80">{f.a}</dd>
          </div>
        ))
      }
    </dl>
    <p class="mt-8">
      <a
        href={withBase('/logistics')}
        class="font-body text-sm font-semibold text-green underline underline-offset-4"
      >
        Read the full FAQ <span aria-hidden="true">&rarr;</span>
      </a>
    </p>
  </Section>

  {/* Teasers — paths into the deeper pages. */}
  <Section bg="cream" space="md" labelledby="explore-heading" class="border-t border-hairline">
    <h2 id="explore-heading" class="sr-only">Explore the wander</h2>
    <ul class="grid gap-8 sm:gap-10 md:grid-cols-3">
      {
        teasers.map((t) => (
          <li>
            <a href={withBase(t.href)} class="teaser group">
              <span class="teaser__index">{t.index}</span>
              <h3 class="teaser__title">{t.title}</h3>
              <p class="teaser__text">{t.text}</p>
              <span class="teaser__more">
                Read more <span aria-hidden="true">&rarr;</span>
              </span>
            </a>
          </li>
        ))
      }
    </ul>
  </Section>
</Layout>
