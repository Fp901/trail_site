---
// The Trail (/the-trail) — Part 8.2 + 2026 brief. No-walking-on-arrival + direct Day-4 departure;
// premium vertical timeline; route map; vista banner.
import { Image } from 'astro:assets';
import Layout from '../layouts/Layout.astro';
import Section from '../components/Section.astro';
import ItineraryTimeline from '../components/ItineraryTimeline.astro';
import RouteMap from '../components/RouteMap.astro';
import { webPageSchema, breadcrumbSchema, touristTripSchema } from '../data/schema';
import { wildlifeGroups, birdingHighlights, wildlifeCounts } from '../data/wildlife';
import vista from '../assets/images/rooiberg-bushveld-vista.jpg';

const title = 'The Trail | Day-by-day slackpacking itinerary';
const description =
  'Day by day through the Rooiberg: arrival, then three 15 to 20 km mountain days over Groenkop, the high ridge to ViervanAcht and the open plains. Self-catered and fully ported.';

const jsonLd = [
  webPageSchema({ path: '/the-trail', name: title, description }),
  breadcrumbSchema([
    { name: 'Home', path: '/' },
    { name: 'The Trail', path: '/the-trail' },
  ]),
  touristTripSchema,
];
---

<Layout title={title} description={description} path="/the-trail" jsonLd={jsonLd}>
  <Section bg="cream" labelledby="trail-heading" space="lg">
    <div class="max-w-3xl">
      <p class="font-body text-sm font-medium uppercase tracking-[0.18em] text-green">
        The Trail · 3 nights / 3 days · ~55 km
      </p>
      <h1 id="trail-heading" class="mt-4 font-display text-4xl text-earth sm:text-5xl md:text-6xl">
        A three-day walking trail through the Rooiberg
      </h1>
      <p class="mt-6 font-body text-lg leading-relaxed text-charcoal sm:text-xl">
        You do not walk on the arrival day, and you leave straight after the final walk on Day 4.
        In between are three walking days of roughly 15 to 20 km: a mountain crossing, a high-ridge
        traverse and a return skirting open grass plains. Each day moves from one safari lodge to
        the next while your luggage and provisions travel ahead, kept cool and dry.
      </p>
      <p class="mt-4 font-body text-base leading-relaxed text-charcoal/80">
        The walking is graded moderate to challenging, over mountain ascents, rocky kloofs and
        rugged ravine terrain. A good level of hiking fitness is required.
      </p>

      <!-- VERIFY WITH OPERATOR -->
      <div class="mt-8 rounded-2xl border border-ochre/50 bg-ochre/10 p-6">
        <p class="font-body text-xs font-semibold uppercase tracking-[0.14em] text-green">
          Before you book
        </p>
        <p class="mt-2 font-display text-xl text-earth">Trail difficulty &amp; fitness</p>
        <p class="mt-3 font-body text-sm leading-relaxed text-charcoal/85">
          Graded <strong>moderate to challenging</strong>. Expect mountain ascents, rocky kloofs and
          rugged ravine terrain over roughly 15 to 20 km a day, so a good level of hiking fitness is
          essential. Sturdy, worn-in walking shoes are a must.
        </p>
      </div>
    </div>
  </Section>

  <figure class="media-band">
    <Image
      src={vista}
      alt="Open bushveld and layered mountains of the Rooiberg, Limpopo, under a wide sky."
      widths={[768, 1280, 1920]}
      sizes="100vw"
      loading="lazy"
    />
  </figure>

  <Section bg="cream" labelledby="itinerary-heading" space="md">
    <h2 id="itinerary-heading" class="font-display text-2xl text-earth sm:text-3xl">
      Day by day
    </h2>
    <div class="mt-10 max-w-3xl sm:mt-12">
      <ItineraryTimeline />
    </div>
  </Section>

  <Section bg="cream" labelledby="route-heading" space="md">
    <div class="max-w-3xl">
      <h2 id="route-heading" class="font-display text-2xl text-earth sm:text-3xl">
        The route
      </h2>
      <p class="mt-5 font-body text-base leading-relaxed text-charcoal/85">
        The Rooiberg Wander is a circuitous trail that begins and ends at Rotavi Lodge: over
        iconic Groenkop to Oukraal, up the high ridges of the Elandsberg L-Kloof to ViervanAcht
        passing the lookout over the Marakele range, and back skirting the open Welgedacht plains
        along the Sand River to Rotavi Lodge. The map below is illustrative.
      </p>
    </div>
    <RouteMap class="mt-10 sm:mt-12" />
  </Section>

  {/* Wildlife & birding — GEO answer-first ("what animals will I see"). */}
  <Section bg="cream" labelledby="wildlife-heading" space="md">
    <div class="max-w-3xl">
      <p class="font-body text-sm font-medium uppercase tracking-[0.18em] text-green">
        Wildlife &amp; birding
      </p>
      <h2 id="wildlife-heading" class="mt-4 font-display text-2xl text-earth sm:text-3xl">
        What you’ll see on foot
      </h2>
      <p class="mt-5 font-body text-base leading-relaxed text-charcoal/85">
        You walk through a Big 5 reserve that holds more than {wildlifeCounts.mammals} mammal
        species and over {wildlifeCounts.birds} recorded birds, from lion, leopard, elephant and
        buffalo to wide-ranging plains game. Tracking is always on foot, with two armed guides.
      </p>
    </div>

    <div class="mt-10 grid gap-6 sm:grid-cols-2">
      {
        wildlifeGroups.map((g) => (
          <article class="wildlife-card">
            <h3 class="wildlife-card__title">{g.title}</h3>
            <p class="wildlife-card__blurb">{g.blurb}</p>
            <ul class="wildlife-card__list">
              {g.species.map((s) => (
                <li>{s}</li>
              ))}
            </ul>
          </article>
        ))
      }
    </div>

    <div class="mt-6 max-w-3xl">
      <article class="wildlife-card">
        <h3 class="wildlife-card__title">Birding highlights</h3>
        <p class="wildlife-card__blurb">
          More than {wildlifeCounts.birds} bird species have been recorded on the reserve. A few of
          the showy, sought-after ones:
        </p>
        <ul class="wildlife-card__list wildlife-card__list--wide">
          {birdingHighlights.map((b) => <li>{b}</li>)}
        </ul>
      </article>
      <p class="mt-5 font-body text-sm italic text-charcoal/75">
        Full bird, mammal and tree species lists are available on request. Sightings are wild and
        never guaranteed.
      </p>
    </div>
  </Section>
</Layout>
