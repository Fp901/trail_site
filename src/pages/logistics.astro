---
// Trail Logistics & FAQ (/logistics) — Part 8.4. Three mandatory blocks (safety emphasised)
// + visible answer-first Q&A (Part 10.5). FAQPage JSON-LD included (Part 10.4, harmless).
import { Image } from 'astro:assets';
import Layout from '../layouts/Layout.astro';
import Section from '../components/Section.astro';
import FaqAccordion from '../components/FaqAccordion.astro';
import {
  logisticsBlocks,
  faqs,
  provisions,
  transfers,
  kitList,
  seasons,
  seasonsIntro,
} from '../data/logistics';
import { webPageSchema, breadcrumbSchema, faqPageSchema } from '../data/schema';
import lion from '../assets/images/big5-lion-rooiberg.jpg';

const title = 'Trail Logistics, Safety & FAQ';
const description =
  'Self-catered with daily porterage and camp staff; two armed trail guides under the Two-Man Rule; moderate-to-challenging grading; 100% malaria-free.';

const jsonLd = [
  webPageSchema({ path: '/logistics', name: title, description }),
  breadcrumbSchema([
    { name: 'Home', path: '/' },
    { name: 'Trail Logistics & FAQ', path: '/logistics' },
  ]),
  faqPageSchema(faqs),
];
---

<Layout title={title} description={description} path="/logistics" jsonLd={jsonLd}>
  <Section bg="cream" labelledby="logistics-heading" space="lg">
    <div class="max-w-3xl">
      <p class="font-body text-sm font-medium uppercase tracking-[0.18em] text-green">
        Before you walk
      </p>
      <h1
        id="logistics-heading"
        class="mt-4 font-display text-4xl text-earth sm:text-5xl md:text-6xl"
      >
        Trail logistics &amp; safety
      </h1>
      <p class="mt-6 font-body text-lg leading-relaxed text-charcoal sm:text-xl">
        How catering, porterage, fitness and safety work on the trail, in a 100% malaria-free
        Big 5 reserve.
      </p>
    </div>
  </Section>

  <figure class="media-band">
    <Image
      src={lion}
      alt="A male lion resting in the Rooiberg bushveld, a Big 5 environment walked on foot with two armed guides."
      widths={[768, 1280, 1920]}
      sizes="100vw"
      loading="lazy"
    />
  </figure>

  <Section bg="cream" space="md" containerClass="!pt-0">
    <div class="max-w-3xl">
      {
        logisticsBlocks.map((b) => (
          <div class:list={['logblock', b.emphasis && 'logblock--safety']}>
            <p class="logblock__kicker">{b.kicker}</p>
            <h2 class="logblock__title">{b.title}</h2>
            <p class="logblock__body">{b.body}</p>
          </div>
        ))
      }
    </div>
  </Section>

  <Section bg="cream" space="md" containerClass="!pt-0">
    <div class="max-w-3xl">
      {/* Food & provisions */}
      <div class="logblock">
        <p class="logblock__kicker">{provisions.kicker}</p>
        <h2 class="logblock__title">{provisions.title}</h2>
        <p class="logblock__body">{provisions.intro}</p>
        <p class="mt-3">
          <a href={provisions.linkUrl} class="info-link">
            {provisions.linkText} <span aria-hidden="true">&rarr;</span>
          </a>
        </p>
        <p class="logblock__body">{provisions.howTo}</p>
        <div class="notice">
          <p class="notice__label">Please note</p>
          <p class="notice__body">{provisions.disclaimer}</p>
        </div>
      </div>

      {/* Transfers & transport */}
      <div class="logblock">
        <p class="logblock__kicker">{transfers.kicker}</p>
        <h2 class="logblock__title">{transfers.title}</h2>
        <p class="logblock__body">{transfers.intro}</p>
        <p class="mt-3">
          <a href={transfers.linkUrl} class="info-link">
            {transfers.linkText} <span aria-hidden="true">&rarr;</span>
          </a>
        </p>
        <p class="logblock__body">{transfers.booking}</p>
        <div class="notice">
          <p class="notice__label">Please note</p>
          <p class="notice__body">{transfers.disclaimer}</p>
        </div>
      </div>
    </div>
  </Section>

  {/* What to pack — day-pack kit list (doubles as SEO: "what to pack for a slackpacking trail"). */}
  <Section bg="cream" space="md" labelledby="pack-heading" containerClass="!pt-0">
    <div class="max-w-3xl">
      <p class="logblock__kicker">{kitList.kicker}</p>
      <h2 id="pack-heading" class="logblock__title">{kitList.title}</h2>
      <p class="logblock__body">{kitList.intro}</p>
      <ul class="mt-6 grid gap-x-8 gap-y-3 sm:grid-cols-2">
        {
          kitList.items.map((item) => (
            <li class="border-l-2 border-ochre pl-3 font-body text-charcoal/90">{item}</li>
          ))
        }
      </ul>
      <p class="mt-6 font-body text-sm italic text-charcoal/75">{kitList.note}</p>
    </div>
  </Section>

  {/* When to walk — the Waterberg seasons (evergreen SEO). */}
  <Section bg="cream" space="md" labelledby="seasons-heading" containerClass="!pt-0">
    <div class="max-w-3xl">
      <p class="logblock__kicker">When to walk</p>
      <h2 id="seasons-heading" class="logblock__title">
        When to walk: the seasons of the Rooiberg Wander
      </h2>
      <p class="logblock__body">{seasonsIntro}</p>
    </div>
    <div class="mt-10 grid gap-6 lg:grid-cols-3">
      {
        seasons.map((s) => (
          <article class="season-card">
            <p class="season-card__months">{s.months}</p>
            <h3 class="season-card__name">{s.name}</h3>
            <p class="season-card__lead">{s.lead}</p>
            <dl class="season-card__detail">
              <dt>Climate</dt>
              <dd>{s.climate}</dd>
              <dt>The experience</dt>
              <dd>{s.experience}</dd>
              <dt>What to pack</dt>
              <dd>{s.pack}</dd>
            </dl>
          </article>
        ))
      }
    </div>
  </Section>

  <Section bg="cream" labelledby="faq-heading" space="md" containerClass="!pt-0">
    <div class="max-w-3xl">
      <h2 id="faq-heading" class="font-display text-2xl text-earth sm:text-3xl">
        Frequently asked questions
      </h2>
      <div class="mt-8">
        <FaqAccordion />
      </div>
    </div>
  </Section>
</Layout>
