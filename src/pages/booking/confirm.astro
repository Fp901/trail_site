---
// Booking confirmation callback (Part 9.2). prerender=false. Verifies the transaction by
// reference for display only — the webhook (verified) is the source of truth for confirmation.
// Resilient when payments aren't configured yet (shows a neutral "confirming" state).
import Layout from '../../layouts/Layout.astro';
import Section from '../../components/Section.astro';
import { payments } from '../../lib/payments';
import { getSupabaseAdmin } from '../../lib/supabase';
import { withBase } from '../../data/site';

export const prerender = false;

const reference = Astro.url.searchParams.get('reference') ?? Astro.url.searchParams.get('trxref');

let state: 'success' | 'pending' | 'error' = 'pending';
let pretripToken: string | null = null;
if (reference) {
  try {
    const result = await payments.verifyTransaction(reference);
    if (result.status === 'success') {
      state = 'success';
    } else {
      // Payment was cancelled or abandoned inside Paystack — redirect to the cancel page which
      // releases the hold immediately and shows a clear "no payment taken" message.
      return Astro.redirect(`/booking/cancel?reference=${encodeURIComponent(reference)}`);
    }
  } catch {
    state = 'error';
  }
  // Fetch the booking's pre-trip token so we can send the guest straight to the details form.
  try {
    const supabase = getSupabaseAdmin();
    const { data } = await supabase
      .from('bookings')
      .select('pretrip_token')
      .eq('processor_reference', reference)
      .maybeSingle();
    pretripToken = data?.pretrip_token ?? null;
  } catch {
    pretripToken = null;
  }
}

const heading =
  state === 'success' ? 'Your booking is confirmed' : 'We’re confirming your booking';
---

<Layout
  title="Booking confirmation | The Rooiberg Wander"
  description="Your Rooiberg Wander booking confirmation."
  path="/booking/confirm"
  noindex={true}
>
  <Section bg="cream" labelledby="confirm-heading" space="lg">
    <div class="max-w-2xl">
      <h1 id="confirm-heading" class="font-display text-4xl text-earth sm:text-5xl">
        {heading}
      </h1>

      {
        state === 'success' && (
          <Fragment>
            <p class="mt-6 font-body text-lg leading-relaxed text-charcoal">
              Thank you. Your payment was received and your exclusive booking is secured. A
              confirmation email and receipt are on their way. We look forward to welcoming
              your group to the Rooiberg.
            </p>
            {pretripToken && (
              <div class="mt-8 rounded-2xl border border-ochre/50 bg-ochre/10 p-6">
                <p class="font-display text-xl text-earth">One more step: your pre-trip details</p>
                <p class="mt-2 font-body leading-relaxed text-charcoal/85">
                  Please complete a few details for your group within 7 days so we can prepare for
                  your trail.
                </p>
                <p class="mt-4">
                  <a href={withBase(`/pretrip/${pretripToken}`)} class="btn btn-primary">
                    Complete your pre-trip details
                  </a>
                </p>
              </div>
            )}
          </Fragment>
        )
      }
      {
        state !== 'success' && (
          <p class="mt-6 font-body text-lg leading-relaxed text-charcoal">
            Thank you. We’re finalising your payment confirmation. If your payment was
            successful you’ll receive a confirmation email shortly, so there’s no need to pay
            again. If anything looks wrong, please contact us.
          </p>
        )
      }

      <p class="mt-8">
        <a href="/" class="btn btn-secondary">Return home</a>
      </p>
    </div>
  </Section>
</Layout>
