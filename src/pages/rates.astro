---
// Rates & Booking (/rates) — Part 8.5. Rates matrix (no VAT charged), what's included, the booking
// area (BookingWidget mounts here at step 12), and the refund/cancellation policy.
import Layout from '../layouts/Layout.astro';
import Section from '../components/Section.astro';
import RatesTable from '../components/RatesTable.astro';
import BookingWidget from '../components/BookingWidget.astro';
import BetaBanner from '../components/BetaBanner.astro';
import InquiryForm from '../components/InquiryForm.astro';
import {
  GROUP_RATE_UNCATERED,
  GROUP_RATE_CATERED,
  SHARED_PP_NIGHT,
  NIGHTS,
  BOOKING_OPEN_DATE,
  formatRand,
  inclusions,
  exclusions,
} from '../data/rates';
import { todaySast } from '../lib/pricing';
import { refundPolicy } from '../data/policies';
import { site } from '../data/site';
import { webPageSchema, breadcrumbSchema, offerSchema } from '../data/schema';
// Official card-network marks (MIT-licensed set; see src/assets/payment/LICENSE.md).
import visaMark from '../assets/payment/visa.svg';
import mastercardMark from '../assets/payment/mastercard.svg';

// Live booking renders only once Supabase + Paystack are configured; until then the page shows
// a "coming soon" note + enquiry. Adding the env vars (then rebuilding) switches it on.
const bookingEnabled = Boolean(
  import.meta.env.PUBLIC_SUPABASE_URL && import.meta.env.PUBLIC_PAYSTACK_PUBLIC_KEY,
);

// Best-effort default for the enquiry disclosure's initial open/closed state (a static build
// can't know "today" at request time) — BetaBanner's own script corrects both it and the banner
// against the visitor's real date on load, so the page self-corrects after 15 Jan 2027 without
// a redeploy.
const isBetaAtBuildTime = todaySast() < BOOKING_OPEN_DATE;

const title = 'Rates & Booking | The Rooiberg Wander';
const description = `Private trail from ${formatRand(GROUP_RATE_UNCATERED)} per group (self-catered) or ${formatRand(GROUP_RATE_CATERED)} catered. Shared Monday departures from ${formatRand(SHARED_PP_NIGHT * NIGHTS)} per person. See what's included and book.`;

const included = inclusions;
const excluded = exclusions;

const jsonLd = [
  webPageSchema({ path: '/rates', name: title, description }),
  breadcrumbSchema([
    { name: 'Home', path: '/' },
    { name: 'Rates & Booking', path: '/rates' },
  ]),
  offerSchema({
    price: GROUP_RATE_UNCATERED,
    name: 'The Rooiberg Wander: private trail, self-catered (exclusive use)',
    description: 'Flat rate for a private group of up to 10, self-catered, incl. conservation levies.',
  }),
  offerSchema({
    price: GROUP_RATE_CATERED,
    name: 'The Rooiberg Wander: private trail, catered (exclusive use)',
    description: 'Flat rate for a private group of up to 10, fully catered, incl. conservation levies.',
  }),
  offerSchema({
    price: SHARED_PP_NIGHT * NIGHTS,
    name: 'The Rooiberg Wander: shared Monday departure (per person)',
    description: 'Shared, fully catered departure, 2 to 8 people, incl. conservation levies.',
  }),
];
---

<Layout title={title} description={description} path="/rates" jsonLd={jsonLd}>
  <Section bg="cream" labelledby="rates-heading" space="lg">
    <div class="max-w-3xl">
      <p class="font-body text-sm font-medium uppercase tracking-[0.18em] text-green">
        Rates &amp; Booking
      </p>
      <h1 id="rates-heading" class="mt-4 font-display text-4xl text-earth sm:text-5xl md:text-6xl">
        What the trail costs
      </h1>
      <p class="mt-6 font-body text-lg leading-relaxed text-charcoal sm:text-xl">
        The private trail is priced <strong>per group, not per person</strong>: one flat rate
        buys exclusive use of the whole trail for up to 10 guests, with two more by special
        arrangement. Prefer to join others? A shared Monday departure is priced per person.
      </p>
    </div>
  </Section>

  <Section bg="cream" space="md" containerClass="!pt-0">
    <BetaBanner />
  </Section>

  <Section bg="cream" labelledby="matrix-heading" space="md" containerClass="!pt-0">
    <h2 id="matrix-heading" class="sr-only">Rates</h2>
    <RatesTable />
    <p class="mt-6 max-w-3xl font-body text-sm text-charcoal/70">
      Prices are in South African Rand. No VAT is charged. A payment receipt is issued on
      confirmation of payment.
    </p>
  </Section>

  <Section bg="cream" labelledby="included-heading" space="md" containerClass="!pt-0">
    <div class="grid gap-10 md:grid-cols-2">
      <div>
        <h2 id="included-heading" class="font-display text-2xl text-earth sm:text-3xl">
          Included in the price
        </h2>
        <ul class="incl-list incl-list--in">
          {included.map((i) => <li>{i}</li>)}
        </ul>
      </div>
      <div>
        <h2 class="font-display text-2xl text-earth sm:text-3xl">What to arrange yourself</h2>
        <ul class="incl-list incl-list--out">
          {excluded.map((i) => <li>{i}</li>)}
        </ul>
      </div>
    </div>
  </Section>

  {/* Booking area — live BookingWidget when configured, else a calm "coming soon" + enquiry. */}
  <Section bg="cream" labelledby="book-heading" space="md" containerClass="!pt-0">
    <div id="book" class="max-w-3xl">
      <h2 id="book-heading" class="font-display text-2xl text-earth sm:text-3xl">
        Booking the trail
      </h2>
      {
        bookingEnabled ? (
          <Fragment>
            <p class="mt-4 font-body leading-relaxed text-charcoal/85">
              Choose your group size and trip type, then a date, and pay securely by card. Your
              booking is confirmed once payment is received, and a receipt is issued by email.
            </p>
            <p class="mt-2 font-body text-sm leading-relaxed text-charcoal/70">
              Private trail: a flat group rate ({formatRand(GROUP_RATE_UNCATERED)} self-catered,
              or {formatRand(GROUP_RATE_CATERED)} catered, regardless of group size), any day
              except Monday. Or join a shared Monday departure, priced per person.
            </p>

            {/* Booking-confidence strip — the friendliest policy facts, at the point of hesitation. */}
            <ul class="booking-assure">
              <li>
                <span class="booking-assure__icon" aria-hidden="true">
                  <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><path d="M8 3v4m8-4v4M4 9h16M5 5h14a1 1 0 0 1 1 1v13a2 2 0 0 1-2 2H6a2 2 0 0 1-2-2V6a1 1 0 0 1 1-1Z"/></svg>
                </span>
                50% deposit secures dates 30+ days out; the balance is due 45 days before arrival
              </li>
              <li>
                <span class="booking-assure__icon" aria-hidden="true">
                  <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><path d="M12 3 5 6v5c0 4.4 3 8.4 7 9.5 4-1.1 7-5.1 7-9.5V6l-7-3Zm-2.5 9 2 2 3.5-4"/></svg>
                </span>
                Instant confirmation and a receipt with every payment
              </li>
            </ul>

            <div class="mt-8">
              <BookingWidget />
            </div>

            {/* Payment trust row — secure-checkout cue at the point of payment. */}
            <p class="payment-trust">
              <span class="payment-trust__lock" aria-hidden="true">
                <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><rect x="4.5" y="10.5" width="15" height="10" rx="2"/><path d="M8 10.5V7.5a4 4 0 0 1 8 0v3M12 14.5v2.5"/></svg>
              </span>
              Secure card payment via Paystack
              <span class="payment-trust__brands">
                <img src={visaMark.src} alt="Visa" width="42" height="27" loading="lazy" />
                <img src={mastercardMark.src} alt="Mastercard" width="42" height="27" loading="lazy" />
              </span>
            </p>
          </Fragment>
        ) : (
          <div class="booking-placeholder">
            <p class="font-body leading-relaxed text-charcoal/85">
              Online booking is being finalised. For now, message us on WhatsApp to check dates and
              reserve your group.
            </p>
            <p class="mt-6">
              <a href={site.contact.whatsappUrl} target="_blank" rel="noopener" class="btn btn-primary">
                Enquire on WhatsApp
              </a>
            </p>
            <p class="mt-4 font-body text-sm text-charcoal/60">
              Secure online booking with instant confirmation is coming soon.
            </p>
          </div>
        )
      }
    </div>
  </Section>

  {/* Refund & cancellation policy (Part 9 / draft in policies.ts). Also referenced at checkout.
      Two summary lines stay visible at all times; the full schedule and clauses collapse into a
      native accordion below them. Policy text itself is unchanged, just re-presented. */}
  <Section bg="cream" labelledby="refund-heading" space="md" containerClass="!pt-0">
    <div class="max-w-3xl">
      <h2 id="refund-heading" class="font-display text-2xl text-earth sm:text-3xl">
        Cancellations &amp; refunds
      </h2>
      <ul class="policy-summary">
        <li>30 or more days before arrival pays a 50% deposit, with the balance due 45 days before arrival; inside 30 days pays in full.</li>
        <li>If we manage to re-book your cancelled dates, you're refunded everything paid less a 10% admin fee.</li>
      </ul>

      <details class="policy-accordion">
        <summary class="policy-accordion__summary">Full cancellation &amp; refund policy</summary>
        <div class="policy-accordion__body">
          <p class="font-body leading-relaxed text-charcoal/85">{refundPolicy.intro}</p>

          <table class="policy-table">
            <caption class="sr-only">Refund schedule by notice given before arrival</caption>
            <thead>
              <tr>
                <th scope="col">Notice before arrival</th>
                <th scope="col">Refund of total paid</th>
              </tr>
            </thead>
            <tbody>
              {
                refundPolicy.tiers.map((t) => (
                  <tr>
                    <th scope="row">{t.window}</th>
                    <td>{t.refund}</td>
                  </tr>
                ))
              }
            </tbody>
          </table>

          <dl class="policy-clauses">
            {
              refundPolicy.clauses.map((c) => (
                <div>
                  <dt>{c.heading}</dt>
                  <dd>{c.body}</dd>
                </div>
              ))
            }
          </dl>
        </div>
      </details>
    </div>
  </Section>

  {/* Enquiry — last section of the page. Open (prominent) while online booking is not yet open
      (before BOOKING_OPEN_DATE); collapses behind a disclosure once booking opens. BetaBanner's
      script sets `open` on load using the visitor's real date, so this self-corrects without a
      deploy. The #enquire-heading anchor is linked from the beta banner and other pages. */}
  {
    bookingEnabled && (
      <Section bg="cream" labelledby="enquire-heading" space="md" containerClass="!pt-0">
        <details class="enquire-disclosure" data-enquire-disclosure data-until={BOOKING_OPEN_DATE} open={isBetaAtBuildTime}>
          <summary class="enquire-disclosure__summary">Prefer to talk to us first?</summary>
          <div class="enquire-disclosure__body max-w-3xl">
            <h2 id="enquire-heading" class="font-display text-2xl text-earth sm:text-3xl">
              Enquire first
            </h2>
            <p class="mt-4 font-body leading-relaxed text-charcoal/85">
              Send us your details and target dates and we’ll be in touch.
            </p>
            <p class="mt-2">
              <a href={site.contact.whatsappUrl} target="_blank" rel="noopener" class="enquire-disclosure__whatsapp">
                or WhatsApp {site.contact.name}
              </a>
            </p>
            <div class="mt-8">
              <InquiryForm />
            </div>
          </div>
        </details>
      </Section>
    )
  }
</Layout>
