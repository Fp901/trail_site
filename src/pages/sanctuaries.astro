---
// The Sanctuaries (/sanctuaries) — Part 8.3. Three distinct nodes, one trail standard.
import Layout from '../layouts/Layout.astro';
import Section from '../components/Section.astro';
import SanctuaryCard from '../components/SanctuaryCard.astro';
import { sanctuaries, sanctuaryAmenities } from '../data/sanctuaries';
import { webPageSchema, breadcrumbSchema, touristAttractionSchema } from '../data/schema';

const title = 'The Safari Lodges | Three private trail lodges';
const description =
  'Rotavi Lodge, Oukraal and ViervanAcht. Three private safari lodges with pools, barbeque, equipped kitchens, safe drinking water and free WiFi.';

const jsonLd = [
  webPageSchema({ path: '/sanctuaries', name: title, description }),
  breadcrumbSchema([
    { name: 'Home', path: '/' },
    { name: 'The Safari Lodges', path: '/sanctuaries' },
  ]),
  ...sanctuaries.map((s) =>
    touristAttractionSchema({ name: s.name, description: s.description }),
  ),
];
---

<Layout title={title} description={description} path="/sanctuaries" jsonLd={jsonLd}>
  <Section bg="cream" labelledby="sanctuaries-heading" space="lg">
    <div class="max-w-3xl">
      <p class="font-body text-sm font-medium uppercase tracking-[0.18em] text-green">
        The Safari Lodges
      </p>
      <h1
        id="sanctuaries-heading"
        class="mt-4 font-display text-4xl text-earth sm:text-5xl md:text-6xl"
      >
        Where you sleep each night
      </h1>
      <p class="mt-6 font-body text-lg leading-relaxed text-charcoal sm:text-xl">
        You sleep at three private safari lodges: Rotavi Lodge, Oukraal and ViervanAcht. Each has
        its own character, and the whole reserve is yours alone for one group of up to ten.
      </p>
      <ul class="mt-8 flex flex-wrap gap-x-6 gap-y-2 font-body text-sm font-medium text-earth">
        {
          sanctuaryAmenities.map((a) => (
            <li class="border-l-2 border-ochre pl-3">{a}</li>
          ))
        }
      </ul>
    </div>
  </Section>

  <Section bg="cream" space="md" containerClass="!pt-0">
    {
      sanctuaries.map((s, i) => (
        <SanctuaryCard
          name={s.name}
          role={s.role}
          description={s.description}
          alt={s.alt}
          accentVar={s.accentVar}
          image={s.image}
          reverse={i % 2 === 1}
        />
      ))
    }
  </Section>
</Layout>
